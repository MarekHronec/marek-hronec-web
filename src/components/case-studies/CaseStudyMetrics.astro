---
/* Used on both the featured card on the listing page and the case study detail page. */

interface Metric {
  label: string;
  value: string;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
---

<ul class="metrics" role="list">
  {metrics.map((m) => (
    <li class="metrics__item">
      <span class="metrics__value">{m.value}</span>
      <span class="metrics__label">{m.label.toUpperCase()}</span>
    </li>
  ))}
</ul>

<style>
  .metrics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-10);
  }

  .metrics__item {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: var(--space-1) 0 var(--space-1) var(--space-3);
    border-left: 2px solid var(--color-primary);
  }

  .metrics__value {
    font-family: var(--font-body);
    font-size: var(--text-title-md);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }

  .metrics__label {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-regular);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-on-surface-muted);
    line-height: 1;
  }
</style>
