---
/**
 * CaseStudyCard — smaller card used in the 2-column grid beneath
 * the featured card on the Case Studies listing page.
 *
 * Layout (per Figma):
 *   ┌────────────────────────────────┐
 *   │  index / category label        │  green uppercase, small
 *   │  Title                         │  Manrope 700, 20px
 *   │  excerpt                       │  body muted
 *   │                                │
 *   │  [TAG]  [TAG]    Case Study →  │  footer row
 *   └────────────────────────────────┘
 *
 * Background: surface-container-low (#f6f3f2) — Figma rgba(246,243,242,1)
 * No drop shadow, no border — tonal surface shift provides separation.
 */

interface Props {
  slug:     string;
  index:    number;       /* 02, 03, … — display number */
  category: string;       /* industry — shown as "02 / Category" */
  title:    string;
  excerpt:  string;
  tags:     string[];
}

const { slug, index, category, title, excerpt, tags } = Astro.props;

/* Zero-pad the index: 2 → "02" */
const indexLabel = String(index).padStart(2, '0');
---

<article class="cs-card">

  <div class="cs-card__body">

    <!-- "02 / Legacy Migration" — Figma: Inter, 9px, primary green, uppercase -->
    <p class="cs-card__category">
      {indexLabel} / {category}
    </p>

    <!-- Title — Manrope 700, 20px, tight tracking -->
    <h3 class="cs-card__title">{title}</h3>

    <!-- Excerpt — Inter regular, 14px, muted -->
    <p class="cs-card__excerpt">{excerpt}</p>

  </div>

  <!-- Footer: tags left, link right — always pinned to bottom of card -->
  <footer class="cs-card__footer">

    <ul class="cs-card__tags" role="list">
      {tags.map((tag) => (
        <li class="cs-card__tag">{tag}</li>
      ))}
    </ul>

    <!-- "Case Study →" link — Figma: Manrope 700, 12px, on-surface charcoal -->
    <a class="cs-card__link" href={`/case-studies/${slug}`} aria-label={`Read case study: ${title}`}>
      Case Study
      <!--
        Arrow icon — simple SVG chevron/arrow matching Figma.
        Uses currentColor so it inherits the link text colour.
      -->
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5"
              stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

  </footer>

</article>

<style>
  /* ── Card shell ───────────────────────────────────────────────────
     surface-container-low (#f6f3f2) lifts the card off the page
     surface without a border — tonal shift per DESIGN.md.
     flex column + space-between pushes footer to the card bottom
     regardless of how much text the body contains.
  ─────────────────────────────────────────────────────────────────── */
  .cs-card {
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-6);
  }

  /* ── Body ─────────────────────────────────────────────────────── */
  .cs-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* "02 / Category" — Figma: Inter 9px uppercase primary green */
  .cs-card__category {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-primary);
  }

  /* Title — Manrope 700, 20px, -1px tracking */
  .cs-card__title {
    font-family: var(--font-display);
    font-size: var(--text-title-lg);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
    margin-top: var(--space-1);
  }

  /* Excerpt — body size, muted */
  .cs-card__excerpt {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
    margin-top: var(--space-1);
  }

  /* ── Footer row ───────────────────────────────────────────────── */
  .cs-card__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
  }

  /* Tag list — horizontal, wrappable */
  .cs-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* Individual tag chip — Figma: surface-container (#e4e2e2), 2px radius, 9px */
  .cs-card__tag {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-regular);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-on-surface);
    background-color: var(--color-secondary-container);
    padding: 2px var(--space-2);
    border-radius: 2px;               /* Figma: very sharp */
  }

  /* "Case Study →" — Manrope 700, 12px, charcoal */
  .cs-card__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-display);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .cs-card__link:hover {
    color: var(--color-primary);
    opacity: 1;
  }
</style>