---
/**
 * ContactChannels — three contact method columns separated by ghost borders
 *
 * Figma: node-17 — full-width, border-top hairline, three equal columns.
 * Each column:
 *   Top row: category type (muted uppercase) + ↗ arrow icon
 *   Bottom: type label (primary uppercase) + value (Manrope 700 30px)
 *
 * Figma column padding: 40px
 * Border separators: rgba(179,178,177,0.2) — ghost borders per DESIGN.md
 */
---

<section class="contact-channels">
  <div class="contact-channels__inner container">

    <!-- Email -->
    <div class="channel-card channel-card--disabled" aria-label="Email coming soon">
      <div class="channel-card__top">
        <span class="channel-card__category">Primary Contact</span>
        <!-- ↗ external arrow icon -->
        <svg class="channel-card__arrow" width="12" height="12" viewBox="0 0 12 12"
             fill="none" aria-hidden="true">
          <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8"
                stroke="currentColor" stroke-width="1.25" stroke-linecap="round"
                stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="channel-card__bottom">
        <span class="channel-card__type">Email</span>
        <span class="channel-card__value">Coming Soon</span>
      </div>
    </div>

    <!-- LinkedIn -->
    <a class="channel-card"
       href="https://www.linkedin.com/in/marekhronec"
       target="_blank"
       rel="noopener noreferrer"
       aria-label="View Marek Hronec on LinkedIn">
      <div class="channel-card__top">
        <span class="channel-card__category">Professional Network</span>
        <svg class="channel-card__arrow" width="12" height="12" viewBox="0 0 12 12"
             fill="none" aria-hidden="true">
          <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8"
                stroke="currentColor" stroke-width="1.25" stroke-linecap="round"
                stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="channel-card__bottom">
        <span class="channel-card__type">LinkedIn</span>
        <span class="channel-card__value channel-card__value--underline">Marek Hronec</span>
      </div>
    </a>

    <!-- Location — no link -->
    <div class="channel-card channel-card--location">
      <div class="channel-card__top">
        <span class="channel-card__category">Global Presence</span>
        <svg class="channel-card__arrow" width="12" height="12" viewBox="0 0 12 12"
             fill="none" aria-hidden="true">
          <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8"
                stroke="currentColor" stroke-width="1.25" stroke-linecap="round"
                stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="channel-card__bottom">
        <span class="channel-card__type">Base Operations</span>
        <span class="channel-card__value">Bratislava, Slovakia</span>
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Section ──────────────────────────────────────────────────────
     Figma: node-17 — border-top hairline across full width.
     The container holds horizontal padding; the row stretches inside.
  ─────────────────────────────────────────────────────────────────── */
  .contact-channels {
    padding-block: 0 var(--space-12);
  }

  /* Three-column row — ghost borders between columns.
     On mobile, stack vertically with a border-bottom separator instead. */
  .contact-channels__inner {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-warm-gray-30);
    border-bottom: 1px solid var(--color-warm-gray-15);
  }

  @media (min-width: 640px) {
    .contact-channels__inner {
      flex-direction: row;
    }
  }

  /* ── Channel card ──────────────────────────────────────────────── */
  .channel-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-7);    /* Figma: 40px */
    flex: 1;
    color: inherit;
    text-decoration: none;
    transition: background-color var(--duration-fast) var(--ease-standard);

    /* Ghost right border between columns */
    border-right: 1px solid var(--color-warm-gray-20);
  }

  /* Last column has no right border */
  .channel-card:last-child {
    border-right: none;
  }

  /* Mobile: bottom separator instead of right */
  @media (max-width: 639px) {
    .channel-card {
      border-right: none;
      border-bottom: 1px solid var(--color-warm-gray-20);
      padding: var(--space-5) 0;
    }

    .channel-card:last-child {
      border-bottom: none;
    }
  }

  /* Subtle hover tint for clickable columns */
  a.channel-card:hover {
    background-color: var(--color-surface-container-low);
    opacity: 1;
  }

  /* Top row: category label + arrow icon */
  .channel-card__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-6);  /* Figma: margin-21 padding-bottom 32px */
  }

  /* "PRIMARY ENTRY" — Figma: Inter 700, 10px, 2px tracking, muted */
  .channel-card__category {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    letter-spacing: 0.15em;    /* Figma: 2px / ~12px ≈ 0.15em */
    text-transform: uppercase;
    color: var(--color-on-surface-muted);
  }

  /* ↗ Arrow — warm gray */
  .channel-card__arrow {
    color: var(--color-warm-gray);
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* location card: arrow is muted (no link) */
  .channel-card--location .channel-card__arrow {
    opacity: 0.5;
  }

  /* Bottom: stacked type label + value */
  .channel-card__bottom {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* "EMAIL" / "LINKEDIN" / "BASE OPERATIONS" — Figma: Inter medium, 12px, primary */
  .channel-card__type {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-medium);
    letter-spacing: 0.05em;    /* Figma: 0.6px / 12px ≈ 0.05em */
    text-transform: uppercase;
    color: var(--color-primary);
  }

  /* Value — Figma: Manrope 700, 30px, -0.75px tracking, line-height 36px */
  .channel-card__value {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.875rem);   /* 30px max */
    font-weight: var(--weight-bold);
    letter-spacing: -0.025em;  /* Figma: -0.75px / 30px = -0.025em */
    line-height: 1.2;
    color: var(--color-on-surface);
  }

  /* LinkedIn value: underlined per Figma */
  .channel-card__value--underline {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>