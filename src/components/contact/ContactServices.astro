---
/**
 * ContactServices — "How I Can Help" section with 3 service cards
 *
 * Figma: node-61
 *   border-top hairline, padding-top 32px, gap 48px between heading and cards
 *   Heading row: "How I Can Help" + horizontal rule (flex:1, rgba(179,178,177,0.3))
 *   3-col card grid:
 *     background: rgba(240,237,237,1) = surface-container
 *     border: 1px solid rgba(179,178,177,0.1) — ghost border
 *     border-radius: 8px (radius-lg)
 *     padding: 32px
 *     SVG icon (primary green) + title (Manrope 700 20px) + body (Inter 14px muted)
 */
---

<section class="contact-services">
  <div class="contact-services__inner container">

    <!-- Heading row with trailing rule — Figma: heading-2-62 -->
    <div class="contact-services__heading-row">
      <h2 class="contact-services__heading">How I Can Help</h2>
      <div class="contact-services__heading-rule" aria-hidden="true"></div>
    </div>

    <!-- 3-column service cards -->
    <div class="services-grid">

      <!-- Architecture Reviews -->
      <div class="service-card">
        <!-- Shield + check icon — Figma: icon-67 (primary green fill) -->
        <svg class="service-card__icon" width="28" height="28" viewBox="0 0 28 28"
             fill="none" aria-hidden="true">
          <path d="M14 3L5 6.5V14c0 5.25 3.89 10.16 9 11.33C19.11 24.16 23 19.25 23 14V6.5L14 3Z"
                stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M10 14l3 3 5-5.5" stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <h3 class="service-card__title">Architecture Reviews</h3>
        <p class="service-card__body">
          Review existing cloud architectures for clarity, scalability, security,
          and operational soundness.
        </p>
      </div>

      <!-- Cloud Strategy -->
      <div class="service-card">
        <!-- Target/location pin icon — Figma: icon-73 -->
        <svg class="service-card__icon" width="28" height="28" viewBox="0 0 28 28"
             fill="none" aria-hidden="true">
          <circle cx="14" cy="12" r="8" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="14" cy="12" r="3.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M14 4V2M14 22v-2M4 12H2M26 12h-2"
                stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M14 20c0 3.314-2 5-2 5s-2-1.686-2-5"
                stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                stroke-linejoin="round"/>
        </svg>
        <h3 class="service-card__title">Cloud Strategy</h3>
        <p class="service-card__body">
          Help shape practical cloud direction, from platform decisions to
          governance and long-term architectural planning.
        </p>
      </div>

      <!-- Process Optimization -->
      <div class="service-card">
        <!-- BPM/flow icon — Figma: icon-79 (two nodes + curve) -->
        <svg class="service-card__icon" width="28" height="28" viewBox="0 0 28 28"
             fill="none" aria-hidden="true">
          <!-- Left node column -->
          <rect x="4" y="5" width="5" height="8" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
          <rect x="4" y="17" width="5" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
          <!-- Right node column -->
          <rect x="19" y="5" width="5" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
          <rect x="19" y="15" width="5" height="8" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
          <!-- Connecting curve -->
          <path d="M9 9C13 9 15 19 19 19" stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round"/>
        </svg>
        <h3 class="service-card__title">Process Optimization</h3>
        <p class="service-card__body">
          Consultation on BPM workflows, automation opportunities, and process
          architecture improvements.
        </p>
      </div>

    </div>

  </div>
</section>

<style>
  /* ── Section ──────────────────────────────────────────────────────
     Figma: node-61 — border-top, padding-top 32px, gap 48px
  ─────────────────────────────────────────────────────────────────── */
  .contact-services {
    padding-block: var(--space-4) var(--space-6);
  }

  .contact-services__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);        /* Figma: gap 48px */
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-warm-gray-30);
  }

  /* Heading row — "How I Can Help" + horizontal rule */
  .contact-services__heading-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);        /* Figma: gap 16px */
  }

  /* "How I Can Help" — Figma: Manrope 700, 30px */
  .contact-services__heading {
    font-family: var(--font-display);
    font-size: var(--text-headline-md);   /* 1.75rem / 28px — close to 30px */
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    white-space: nowrap;
    letter-spacing: var(--tracking-tight);
  }

  /* Trailing rule — Figma: flex:1, rgba(179,178,177,0.3) bg, 1px height */
  .contact-services__heading-rule {
    flex: 1;
    height: 1px;
    background-color: var(--color-warm-gray-30);
  }

  /* ── 3-column card grid ───────────────────────────────────────────
     Equal-width cards; stack on mobile, 3-col at 768px+
  ─────────────────────────────────────────────────────────────────── */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Service card ──────────────────────────────────────────────── */
  .service-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);        /* Figma: items stacked, generous gap */
    padding: var(--space-6);    /* Figma: 32px */
    background-color: var(--color-surface-container);   /* rgba(240,237,237,1) */
    border: 1px solid var(--color-warm-gray-10);         /* ghost border */
    border-radius: var(--radius-lg);                     /* Figma: 8px = radius-lg */
  }

  /* SVG icon — Figma: primary green fill */
  .service-card__icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  /* Title — Figma: Manrope 700, 20px */
  .service-card__title {
    font-family: var(--font-display);
    font-size: var(--text-title-md);    /* 1.125rem / 18px — closest to 20px */
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }

  /* Body — Figma: Inter regular, 14px (body-md), muted */
  .service-card__body {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    line-height: 1.625;          /* Figma: 22.75px / 14px */
    color: var(--color-on-surface-muted);
  }
</style>