---
import ShieldCheck from '../icons/ShieldCheck.astro';
import Target from '../icons/Target.astro';
import Workflow from '../icons/Workflow.astro';
---

<section class="contact-services">
  <div class="contact-services__inner container">

    <div class="contact-services__heading-row">
      <h2 class="contact-services__heading">How I Can Help</h2>
      <div class="contact-services__heading-rule" aria-hidden="true"></div>
    </div>

    <div class="services-grid">

      <div class="service-card">
        <ShieldCheck size={28} class="service-card__icon" aria-hidden="true" />
        <h3 class="service-card__title">Architecture Reviews</h3>
        <p class="service-card__body">
          Review existing cloud architectures for clarity, scalability, security,
          and operational soundness.
        </p>
      </div>

      <div class="service-card">
        <Target size={28} class="service-card__icon" aria-hidden="true" />
        <h3 class="service-card__title">Cloud Strategy</h3>
        <p class="service-card__body">
          Help shape practical cloud direction, from platform decisions to
          governance and long-term architectural planning.
        </p>
      </div>

      <div class="service-card">
        <Workflow size={28} class="service-card__icon" aria-hidden="true" />
        <h3 class="service-card__title">Process Optimization</h3>
        <p class="service-card__body">
          Consultation on BPM workflows, automation opportunities, and process
          architecture improvements.
        </p>
      </div>

    </div>

  </div>
</section>

<style>
  .contact-services {
    padding-block: var(--space-4) var(--space-6);
  }

  .contact-services__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-warm-gray-30);
  }

  /* Same heading + trailing rule pattern as the Experience section */
  .contact-services__heading-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .contact-services__heading {
    font-family: var(--font-display);
    font-size: var(--text-headline-md);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    white-space: nowrap;
    letter-spacing: var(--tracking-tight);
  }

  .contact-services__heading-rule {
    flex: 1;
    height: 1px;
    background-color: var(--color-warm-gray-30);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    background-color: var(--color-surface-container);
    border: 1px solid var(--color-warm-gray-10);
    border-radius: var(--radius-lg);
  }

  .service-card__icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .service-card__title {
    font-family: var(--font-display);
    font-size: var(--text-title-md);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }

  .service-card__body {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    line-height: 1.625;
    color: var(--color-on-surface-muted);
  }
</style>
