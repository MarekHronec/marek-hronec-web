---
---

<section class="contact-hero">
  <div class="contact-hero__inner container">

    <div class="contact-hero__content">
      <p class="contact-hero__label">Direct Communications</p>
      <h1 class="contact-hero__heading">
        Let's architect the
        <em class="contact-hero__heading--accent">future</em>
        of your cloud ecosystem<span class="contact-hero__period">.</span>
      </h1>
      <p class="contact-hero__body">
        Available for complex cloud transformations, high-availability
        infrastructure reviews, and technical advisory roles. Reach out via a
        direct channel below.
      </p>
    </div>

    <!-- Availability card — bottom-aligns with the body paragraph via flex-end on the row -->
    <div class="contact-hero__aside">
      <div class="contact-hero__availability">
        <span class="contact-hero__availability-label">Current Availability</span>
        <span class="contact-hero__availability-value">
          Accepting 2026 Consulting Projects
        </span>
      </div>
    </div>

  </div>
</section>

<style>
  .contact-hero {
    padding-block: var(--space-8) var(--space-6);
  }

  .contact-hero__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .contact-hero__inner {
      flex-direction: row;
      /* flex-end aligns the card's bottom edge with the body text bottom */
      align-items: flex-end;
      gap: var(--space-8);
    }
  }

  .contact-hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    flex: 1;
    padding-top: var(--space-4);
  }

  .contact-hero__label {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .contact-hero__heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, var(--text-display-lg));
    font-weight: var(--weight-bold);
    letter-spacing: -0.05em;
    line-height: 1;
    color: var(--color-on-surface);
  }

  /* "future" is in <em> but we want the teal color, not italic */
  .contact-hero__heading--accent {
    color: var(--color-primary);
    font-style: normal;
  }

  .contact-hero__period {
    color: var(--color-meta-label);
  }

  .contact-hero__body {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
    max-width: 42ch;
  }

  .contact-hero__aside {
    flex-shrink: 0;
    width: 100%;
  }

  @media (min-width: 768px) {
    .contact-hero__aside {
      width: auto;
      min-width: 260px;
      max-width: 320px;
    }
  }

  .contact-hero__availability {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
    background-color: var(--color-surface-container-low);
    border-left: 4px solid var(--color-primary);
    border-radius: var(--radius-sm);
  }

  .contact-hero__availability-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-regular);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-on-surface-muted);
  }

  .contact-hero__availability-value {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    font-weight: var(--weight-medium);
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }
</style>