---
import TagBadge from '../shared/TagBadge.astro';
import { base } from '../../utils/base';
import { sortTagsByPriority } from '../../utils/tagPriority';

interface Props {
  slug: string;
  title: string;
  category: string;
  excerpt: string;
  date: Date;
  readTime: number;
  level: 'beginner' | 'intermediate' | 'advanced';
  tags: string[];
}

const { slug, title, excerpt, date, readTime, level, tags } = Astro.props;

const levelLabel = { beginner: 'Beginner', intermediate: 'Intermediate', advanced: 'Advanced' }[level];

const MOBILE_MAX = 3;
const DESKTOP_MAX = 5;

// Level badge always first, then priority-sorted article tags
const allDisplayTags = [levelLabel, ...sortTagsByPriority(tags)];

// Server renders the mobile-conservative visible set to prevent flash
const visibleTags   = allDisplayTags.slice(0, MOBILE_MAX);
const hiddenTags    = allDisplayTags.slice(MOBILE_MAX);

// Indices 0..(DESKTOP_MAX-MOBILE_MAX-1) of hiddenTags are desktop extras (shown in compact on desktop)
const desktopRevealCount = Math.min(hiddenTags.length, DESKTOP_MAX - MOBILE_MAX);

const mobileHiddenCount  = hiddenTags.length;
const desktopHiddenCount = Math.max(0, allDisplayTags.length - DESKTOP_MAX);

const dateStr = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const href = `${base}/knowledge-base/${slug}`;
---

<article class="article-card">

  <h2 class="article-card__title">{title}</h2>
  <div class="article-card__meta">
    <span>{dateStr}</span>
    <span class="article-card__meta-dot" aria-hidden="true">·</span>
    <span>{readTime} min read</span>
  </div>
  <p class="article-card__excerpt">{excerpt}</p>

  <footer class="article-card__footer">
    <ul class="article-card__tags" role="list">

      {/* Always visible — first MOBILE_MAX tags */}
      {visibleTags.map(tag => (
        <li><TagBadge label={tag} /></li>
      ))}

      {/* Hidden tags — JS manages visibility based on viewport + expand state */}
      {hiddenTags.map((tag, i) => (
        <li class={`tag-hidden${i < desktopRevealCount ? ' tag-desktop' : ''}`}>
          <TagBadge label={tag} />
        </li>
      ))}

      {/* +N expand button — only rendered when there are hidden tags on mobile */}
      {mobileHiddenCount > 0 && (
        <li class="tag-more">
          <button
            class="tag-more-btn"
            aria-expanded="false"
            aria-label={`Show ${mobileHiddenCount} more tags`}
            data-mobile-hidden={mobileHiddenCount}
            data-desktop-hidden={desktopHiddenCount}
          >+{mobileHiddenCount}</button>
        </li>
      )}

    </ul>
    <a class="article-card__link" href={href} aria-label={`Read article: ${title}`}>
      Read Article
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5"
              stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </footer>

</article>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-md);
    width: 100%;
    height: 100%;
    transition: background-color var(--duration-fast) var(--ease-standard);
  }

  .article-card:hover {
    background-color: var(--color-surface-container);
  }

  .article-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    color: var(--color-kb-text-muted);
    white-space: nowrap;
  }

  .article-card__meta-dot {
    opacity: 0.5;
  }

  .article-card__title {
    font-family: var(--font-display);
    font-size: var(--text-title-lg);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }

  .article-card__excerpt {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
    flex: 1;
  }

  .article-card__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  .article-card__tags {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
  }

  /* Hidden until JS reveals (desktop extras or expand) */
  .tag-hidden {
    display: none;
  }

  /* +N button — same visual as TagBadge but interactive */
  .tag-more-btn {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-label-sm);
    font-weight: var(--weight-regular);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-meta-label);
    background-color: var(--color-secondary-container);
    padding: 2px 6px;
    border-radius: 2px;
    white-space: nowrap;
    cursor: pointer;
    transition:
      background-color var(--duration-fast) var(--ease-standard),
      color var(--duration-fast) var(--ease-standard);
  }

  .tag-more-btn:hover {
    background-color: var(--color-surface-container);
    color: var(--color-on-surface);
  }

  .tag-more-btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .article-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-display);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    white-space: nowrap;
    flex-shrink: 0;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .article-card:hover .article-card__link {
    color: var(--color-primary);
  }
</style>

<script>
  (function initTagExpansion() {
    const BREAKPOINT = 640;

    function initCard(tagsEl: HTMLElement) {
      const hiddenItems = Array.from(tagsEl.querySelectorAll<HTMLElement>('.tag-hidden, .tag-desktop'));
      const moreItem    = tagsEl.querySelector<HTMLElement>('.tag-more');
      const moreBtn     = tagsEl.querySelector<HTMLButtonElement>('.tag-more-btn');

      if (!moreBtn || !moreItem) return;

      // Assign to const so TypeScript trusts non-null inside closures
      const btn  = moreBtn;
      const more = moreItem;

      const mobileHidden  = parseInt(btn.dataset.mobileHidden  ?? '0', 10);
      const desktopHidden = parseInt(btn.dataset.desktopHidden ?? '0', 10);
      let expanded = false;

      function isMobile(): boolean {
        return !window.matchMedia(`(min-width: ${BREAKPOINT}px)`).matches;
      }

      function applyCompact() {
        const mobile      = isMobile();
        const hiddenCount = mobile ? mobileHidden : desktopHidden;

        hiddenItems.forEach(item => {
          // Desktop extras (tag-desktop): visible on desktop compact, hidden on mobile compact
          const isDesktopExtra = item.classList.contains('tag-desktop');
          item.classList.toggle('tag-hidden', mobile || !isDesktopExtra);
        });

        if (hiddenCount > 0) {
          more.hidden = false;
          btn.textContent = `+${hiddenCount}`;
          btn.setAttribute('aria-label', `Show ${hiddenCount} more tags`);
          btn.setAttribute('aria-expanded', 'false');
        } else {
          more.hidden = true;
        }
      }

      function applyExpanded() {
        hiddenItems.forEach(item => item.classList.remove('tag-hidden'));
        more.hidden = false;
        btn.textContent = '−';
        btn.setAttribute('aria-label', 'Hide additional tags');
        btn.setAttribute('aria-expanded', 'true');
      }

      btn.addEventListener('click', () => {
        expanded = !expanded;
        expanded ? applyExpanded() : applyCompact();
      });

      // Re-evaluate compact state on breakpoint change (without disturbing user-expanded state)
      window.matchMedia(`(min-width: ${BREAKPOINT}px)`)
        .addEventListener('change', () => { if (!expanded) applyCompact(); });

      applyCompact();
    }

    document.querySelectorAll<HTMLElement>('.article-card__tags').forEach(initCard);
  })();
</script>
