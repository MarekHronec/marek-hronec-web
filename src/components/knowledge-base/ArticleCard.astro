---
import TagBadge from '../shared/TagBadge.astro';

interface Props {
  slug: string;
  title: string;
  category: string;
  excerpt: string;
  date: Date;
  readTime: number;
  level: 'beginner' | 'intermediate' | 'advanced';
  tags: string[];
}

const { slug, title, category, excerpt, date, readTime, level, tags } = Astro.props;

const levelLabel = { beginner: 'Beginner', intermediate: 'Intermediate', advanced: 'Advanced' }[level];

const dateStr = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const href = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/knowledge-base/${slug}`;
---

<article class="article-card">

  <div class="article-card__header">
    <p class="article-card__category">{category.toUpperCase()}</p>
    <div class="article-card__meta">
      <span>{dateStr}</span>
      <span class="article-card__meta-dot" aria-hidden="true">·</span>
      <span>{readTime} min read</span>
    </div>
  </div>

  <h2 class="article-card__title">{title}</h2>
  <p class="article-card__excerpt">{excerpt}</p>

  <footer class="article-card__footer">
    <ul class="article-card__tags" role="list">
      <li><TagBadge label={levelLabel} /></li>
      {tags.map((tag) => (
        <li><TagBadge label={tag} /></li>
      ))}
    </ul>
    <a class="article-card__link" href={href} aria-label={`Read article: ${title}`}>
      Read Article
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5"
              stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </footer>

</article>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-md);
    width: 100%;
    height: 100%;
    transition: background-color var(--duration-fast) var(--ease-standard);
  }

  .article-card:hover {
    background-color: var(--color-surface-container);
  }

  .article-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .article-card__category {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    color: var(--color-primary);
  }

  .article-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    color: var(--color-kb-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .article-card__meta-dot {
    opacity: 0.5;
  }

  .article-card__title {
    font-family: var(--font-display);
    font-size: var(--text-title-lg);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }

  .article-card__excerpt {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
    flex: 1;
  }

  .article-card__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  .article-card__tags {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
  }

  .article-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-display);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    white-space: nowrap;
    flex-shrink: 0;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .article-card__link:hover {
    color: var(--color-primary);
    opacity: 1;
  }
</style>
