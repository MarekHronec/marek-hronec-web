---
// Filter panel for Knowledge Base listing + article detail pages.
// Filter state, counts, and active styling are managed by JS in index.astro.
// This component only renders the HTML scaffolding.
---

<aside class="kb-filter">
  <div class="kb-filter__sticky">

    <header class="kb-filter__header">
      <p class="kb-filter__eyebrow">Knowledge Base</p>
      <h2 class="kb-filter__title">Filter Articles</h2>
    </header>

    <div class="kb-filter__group">
      <p class="kb-filter__group-label">Platforms</p>
      <ul class="kb-filter__options" role="list">
        <li>
          <button class="kb-filter__btn" data-filter-group="platform" data-filter-value="azure" aria-pressed="false">
            <span>Azure</span><span class="kb-filter__count"></span>
          </button>
        </li>
        <li>
          <button class="kb-filter__btn" data-filter-group="platform" data-filter-value="oci" aria-pressed="false">
            <span>OCI</span><span class="kb-filter__count"></span>
          </button>
        </li>
      </ul>
    </div>

    <div class="kb-filter__group">
      <p class="kb-filter__group-label">Topics</p>
      <ul class="kb-filter__options" role="list">
        {[
          ['networking',    'Networking'],
          ['identity',      'Identity'],
          ['security',      'Security'],
          ['finops',        'FinOps'],
          ['landing-zones', 'Landing Zones'],
          ['devops',        'DevOps'],
          ['bpm',           'BPM'],
        ].map(([value, label]) => (
          <li>
            <button class="kb-filter__btn" data-filter-group="topic" data-filter-value={value} aria-pressed="false">
              <span>{label}</span><span class="kb-filter__count"></span>
            </button>
          </li>
        ))}
      </ul>
    </div>

    <button class="kb-filter__clear" id="kb-clear-filters" hidden>
      Clear filters
    </button>

  </div>
</aside>

<!-- ── Mobile filter bar (fixed at bottom on mobile) ─────────────── -->
<div class="kb-mobile-bar">
  <button
    class="kb-mobile-bar__trigger"
    id="kb-mobile-trigger"
    aria-expanded="false"
    aria-controls="kb-mobile-sheet"
  >
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M2 4.5h12M2 8h8M2 11.5h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    Filter Articles
    <span class="kb-mobile-bar__badge" id="kb-mobile-badge" hidden></span>
    <svg class="kb-mobile-bar__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <path d="M2 8l4-4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</div>

<!-- ── Mobile sheet overlay ──────────────────────────────────────── -->
<div class="kb-sheet-overlay" id="kb-sheet-overlay" aria-hidden="true">
  <div class="kb-mobile-sheet" id="kb-mobile-sheet" role="dialog" aria-label="Filter articles">
    <div class="kb-mobile-sheet__handle"></div>
    <div class="kb-mobile-sheet__head">
      <p class="kb-mobile-sheet__title">Filter Articles</p>
      <button class="kb-mobile-sheet__close" id="kb-sheet-close" aria-label="Close filters">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="kb-mobile-sheet__nav">
      <p class="kb-mobile-sheet__group-label">Platforms</p>
      <ul class="kb-mobile-sheet__options" role="list">
        <li>
          <button class="kb-filter__btn kb-mobile-sheet__btn" data-filter-group="platform" data-filter-value="azure" aria-pressed="false">
            <span>Azure</span><span class="kb-filter__count"></span>
          </button>
        </li>
        <li>
          <button class="kb-filter__btn kb-mobile-sheet__btn" data-filter-group="platform" data-filter-value="oci" aria-pressed="false">
            <span>OCI</span><span class="kb-filter__count"></span>
          </button>
        </li>
      </ul>
      <p class="kb-mobile-sheet__group-label">Topics</p>
      <ul class="kb-mobile-sheet__options" role="list">
        {[
          ['networking',    'Networking'],
          ['identity',      'Identity'],
          ['security',      'Security'],
          ['finops',        'FinOps'],
          ['landing-zones', 'Landing Zones'],
          ['devops',        'DevOps'],
          ['bpm',           'BPM'],
        ].map(([value, label]) => (
          <li>
            <button class="kb-filter__btn kb-mobile-sheet__btn" data-filter-group="topic" data-filter-value={value} aria-pressed="false">
              <span>{label}</span><span class="kb-filter__count"></span>
            </button>
          </li>
        ))}
      </ul>
      <button class="kb-mobile-sheet__clear" id="kb-mobile-clear" hidden>
        Clear all filters
      </button>
    </div>
  </div>
</div>

<style>
  /* ── Desktop filter panel ──────────────────────────────────────── */
  .kb-filter {
    width: 240px;
    flex-shrink: 0;
    background-color: var(--color-surface-container-lowest);
  }

  .kb-filter__sticky {
    position: sticky;
    top: 64px;
    max-height: calc(100vh - 64px);
    overflow-y: auto;
    padding: var(--space-6) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .kb-filter__header {
    padding: 0 var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .kb-filter__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .kb-filter__title {
    font-family: var(--font-display);
    font-size: var(--text-title-md);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    margin: 0;
  }

  .kb-filter__group {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .kb-filter__group-label {
    padding: 0 var(--space-5) var(--space-1);
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-kb-text-muted);
  }

  .kb-filter__options {
    display: flex;
    flex-direction: column;
    list-style: none;
  }

  /* Shared filter button — desktop panel */
  .kb-filter__btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-2) var(--space-5);
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-kb-text);
    background: transparent;
    cursor: pointer;
    text-align: left;
    border-right: 3px solid transparent;
    transition:
      color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard);
  }

  .kb-filter__btn:hover {
    color: var(--color-primary);
    background-color: var(--color-level-advanced-bg-dim);
  }

  .kb-filter__btn[aria-pressed="true"] {
    color: var(--color-level-advanced-text);
    background-color: var(--color-level-advanced-bg);
    border-right-color: var(--color-level-advanced-text);
  }

  .kb-filter__count {
    font-size: var(--text-label-md);
    font-weight: var(--weight-regular);
    color: var(--color-kb-text-muted);
    min-width: 1.5em;
    text-align: right;
  }

  .kb-filter__btn[aria-pressed="true"] .kb-filter__count {
    color: var(--color-level-advanced-text);
    opacity: 0.75;
  }

  .kb-filter__clear {
    margin: 0 var(--space-5);
    padding: var(--space-2) 0;
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-primary);
    background: transparent;
    cursor: pointer;
    text-align: left;
    transition: opacity var(--duration-fast) var(--ease-standard);
  }

  .kb-filter__clear:hover {
    opacity: 0.7;
  }

  /* ── Mobile bottom bar ──────────────────────────────────────────
     Hidden on desktop, fixed at bottom on mobile.
  ─────────────────────────────────────────────────────────────────── */
  .kb-mobile-bar {
    display: none;
  }

  @media (max-width: 767px) {
    .kb-mobile-bar {
      display: block;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 50;
      background: var(--glass-bg);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border-top: 1px solid var(--glass-border);
      padding: var(--space-3) var(--gutter);
      padding-bottom: calc(var(--space-3) + env(safe-area-inset-bottom, 0px));
    }
  }

  .kb-mobile-bar__trigger {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    width: 100%;
    padding: var(--space-2) var(--space-4);
    background: var(--color-surface-container-low);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    font-weight: var(--weight-medium);
    color: var(--color-on-surface);
    cursor: pointer;
    text-align: left;
  }

  .kb-mobile-bar__trigger svg:first-child {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .kb-mobile-bar__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 var(--space-1);
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-radius: var(--radius-full);
    font-size: 0.625rem;
    font-weight: var(--weight-bold);
    line-height: 1;
  }

  .kb-mobile-bar__chevron {
    margin-left: auto;
    color: var(--color-on-surface-muted);
    transition: transform var(--duration-fast) var(--ease-standard);
  }

  .kb-mobile-bar__trigger[aria-expanded="true"] .kb-mobile-bar__chevron {
    transform: rotate(180deg);
  }

  /* ── Sheet overlay ──────────────────────────────────────────────── */
  .kb-sheet-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 98;
  }

  .kb-sheet-overlay--open {
    display: block;
  }

  .kb-sheet-overlay::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-overlay);
  }

  .kb-mobile-sheet {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--color-surface);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    max-height: 80vh;
    overflow-y: auto;
    transform: translateY(100%);
    transition: transform var(--duration-normal) var(--ease-standard);
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  .kb-sheet-overlay--open .kb-mobile-sheet {
    transform: translateY(0);
  }

  .kb-mobile-sheet__handle {
    width: 40px;
    height: 4px;
    background: var(--color-outline-variant);
    border-radius: var(--radius-full);
    margin: var(--space-3) auto var(--space-2);
  }

  .kb-mobile-sheet__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-5) var(--space-4);
  }

  .kb-mobile-sheet__title {
    font-family: var(--font-display);
    font-size: var(--text-title-md);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
  }

  .kb-mobile-sheet__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    background: var(--color-surface-container-low);
    color: var(--color-on-surface-muted);
    cursor: pointer;
    flex-shrink: 0;
  }

  .kb-mobile-sheet__nav {
    display: flex;
    flex-direction: column;
    padding: 0 0 var(--space-8);
  }

  .kb-mobile-sheet__group-label {
    padding: var(--space-3) var(--space-5) var(--space-1);
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-kb-text-muted);
  }

  .kb-mobile-sheet__options {
    display: flex;
    flex-direction: column;
    list-style: none;
  }

  /* Override desktop panel styles for mobile sheet buttons */
  .kb-mobile-sheet__btn {
    border-right: none;
    padding: var(--space-3) var(--space-5);
    font-size: var(--text-body-md);
    letter-spacing: 0.04em;
  }

  .kb-mobile-sheet__btn[aria-pressed="true"] {
    border-right: none;
  }

  .kb-mobile-sheet__clear {
    margin: var(--space-4) var(--space-5) 0;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    font-weight: var(--weight-semibold);
    color: var(--color-primary);
    background: var(--color-surface-container-low);
    border-radius: var(--radius-sm);
    cursor: pointer;
    text-align: center;
    width: calc(100% - var(--space-5) * 2);
  }
</style>

<script>
  /* ── Mobile sheet open/close ──────────────────────────────────── */
  const trigger = document.getElementById('kb-mobile-trigger') as HTMLButtonElement | null;
  const overlay = document.getElementById('kb-sheet-overlay') as HTMLElement | null;
  const closeBtn = document.getElementById('kb-sheet-close') as HTMLButtonElement | null;

  function openSheet() {
    overlay?.classList.add('kb-sheet-overlay--open');
    overlay?.removeAttribute('aria-hidden');
    trigger?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeSheet() {
    overlay?.classList.remove('kb-sheet-overlay--open');
    overlay?.setAttribute('aria-hidden', 'true');
    trigger?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  trigger?.addEventListener('click', () =>
    trigger.getAttribute('aria-expanded') === 'true' ? closeSheet() : openSheet()
  );

  closeBtn?.addEventListener('click', closeSheet);

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeSheet();
  });
</script>
