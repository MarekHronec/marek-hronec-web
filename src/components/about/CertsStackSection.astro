---
/*
 * Certifications + Technical Stack side by side.
 * align-items: stretch keeps both cards the same height.
 * The section has no background of its own — it merges visually
 * with NarrativeSection above because the card surface tones match.
 */

import BadgeCheck from "../icons/BadgeCheck.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

interface Cert {
  name: string;
  level: string;
}

interface TechCategory {
  name: string;
  items: string[];
}

/*
 * A column can hold one or two stacked TechCategory sections.
 * Orchestration + Languages share column 3 so the grid stays at 4 columns
 * instead of spreading to 5.
 */
interface TechColumn {
  sections: TechCategory[];
}

const certifications: Cert[] = [
  { name: "Azure Solutions Architect Expert", level: "AZ-305" },
  { name: "Oracle Cloud Infrastructure Architect", level: "Associate Level" },
  { name: "Oracle Multicloud Architect", level: "Professional Level" },
];

const columns: TechColumn[] = [
  {
    sections: [
      {
        name: "Infrastructure",
        items: [
          "Microsoft Azure",
          "Azure ExpressRoute",
          "Oracle Cloud (OCI)",
          "GitHub",
          "GitHub Actions",
          "Terraform",
        ],
      },
    ],
  },
  {
    sections: [
      {
        name: "Containers",
        items: ["Kubernetes", "Azure App Service", "Docker"],
      },
      { name: "Orchestration", items: ["Camunda BPM", "Oracle BPM"] },
    ],
  },
  {
    sections: [
      {
        name: "Observability",
        items: ["Power BI", "Tableau", "Grafana", "Cloud-native tools"],
      },
    ],
  },
  {
    sections: [
      {
        name: "Modeling",
        items: ["Sparx EA", "BiZZdesign", "Archi", "BPMN Modelers", "draw.io"],
      },
    ],
  },
];
---

<section class="cs">
  <div class="cs__inner container">
    <div class="cs__certs">
      <p class="cs__label">Certifications</p>
      <ul class="cs__cert-list" role="list">
        {
          certifications.map((cert) => (
            <li class="cs__cert-item">
              <span class="cs__cert-check" aria-hidden="true">
                <BadgeCheck size={20} aria-hidden="true" />
              </span>
              <div class="cs__cert-text">
                <span class="cs__cert-name">{cert.name}</span>
                <span class="cs__cert-level">{cert.level}</span>
              </div>
            </li>
          ))
        }
      </ul>

      <a class="cs__certs-link" href={`${base}/credentials`}>
        View all certifications
        <svg
          width="12"
          height="12"
          viewBox="0 0 12 12"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M2 6h8M7 3l3 3-3 3"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <div class="cs__stack">
      <p class="cs__label">Technical Stack</p>
      <div class="cs__stack-grid">
        {
          columns.map((col) => (
            <div class="cs__stack-col">
              {col.sections.map((section: TechCategory) => (
                <div class="cs__stack-section">
                  <h3 class="cs__stack-heading">
                    {section.name.toUpperCase()}
                  </h3>
                  <ul class="cs__stack-items" role="list">
                    {section.items.map((item: string) => (
                      <li class="cs__stack-item">{item}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .cs {
    padding-block: 0 var(--space-6);
  }

  /* align-items: stretch so both cards always share the same height */
  .cs__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .cs__inner {
      /* 320px cert card is wide enough that long cert names don't wrap */
      grid-template-columns: 320px 1fr;
    }
  }

  /* The two cards use slightly different surface tones so they read as separate
     without needing a border between them. */
  .cs__certs {
    background-color: var(--color-surface-container);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
  }

  .cs__stack {
    background-color: var(--color-surface-container-high);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .cs__label {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-on-surface);
    margin-bottom: var(--space-4);
  }

  .cs__cert-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .cs__cert-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .cs__cert-check {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 1px; /* optical alignment with the cert name text */
  }

  .cs__cert-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .cs__cert-name {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    font-weight: var(--weight-semibold);
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }

  .cs__cert-level {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    color: var(--color-on-surface-muted);
  }

  .cs__stack-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: var(--space-5);
    row-gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .cs__stack-grid {
      grid-template-columns: repeat(3, 1fr);
      column-gap: var(--space-5);
    }
  }

  @media (min-width: 1024px) {
    .cs__stack-grid {
      grid-template-columns: repeat(4, 1fr);
      column-gap: var(--space-5);
      row-gap: var(--space-4);
    }
  }

  .cs__stack-section {
    margin-bottom: var(--space-4);
  }

  .cs__stack-section:last-child {
    margin-bottom: 0;
  }

  .cs__stack-heading {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .cs__stack-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cs__stack-item {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    color: var(--color-on-surface-muted);
    line-height: var(--leading-snug);
  }

  .cs__certs-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin-top: auto;
    padding-top: var(--space-5);
    align-self: flex-end;
    font-family: var(--font-display);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-standard);
  }

  .cs__certs-link:hover {
    opacity: 0.75;
  }
</style>
