---
---

<!-- Section has no background so the green card stays bounded by container max-width — no full-bleed color at wide viewports. -->
<section class="cta-section">
  <div class="cta-section__container container">
    <div class="cta-banner">
      <div class="cta-banner__content">
        <h2 class="cta-banner__heading">Let's simplify the complex.</h2>
        <p class="cta-banner__body">
          From architecture reviews to cloud strategy, I help turn
          complexity into clear and practical decisions.
        </p>
      </div>
      <a class="cta-banner__button" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/contact`}>
        Schedule a Consultation
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding-block: 0 var(--space-6);
  }

  .cta-section__container {
    padding-inline: var(--gutter);
  }

  .cta-banner {
    background-color: var(--color-cta-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-8) var(--space-10);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .cta-banner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-10);
    }
  }

  .cta-banner__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 52ch;
  }

  .cta-banner__heading {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, var(--text-headline-md));
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-primary);
    line-height: var(--leading-tight);
  }

  .cta-banner__body {
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    /* dark primary at 80% — reads as body text, not a competing heading */
    color: rgba(29, 92, 66, 0.8);
  }

  .cta-banner__button {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    flex-shrink: 0;
    padding: var(--space-3) var(--space-7);
    background-color: var(--color-primary);
    color: var(--color-on-cta);
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    font-weight: var(--weight-semibold);
    /* intentionally sharp — no radius token */
    border-radius: 2px;
    transition: transform var(--duration-fast) var(--ease-standard),
                opacity var(--duration-fast) var(--ease-standard);
  }

  .cta-banner__button:hover {
    opacity: 1;
    transform: translateY(-2px);
  }
</style>
