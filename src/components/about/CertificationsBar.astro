---
import BadgeCheck from '../icons/BadgeCheck.astro';

const certifications = [
  {
    name: 'Azure Solution Architect Expert',
    code: 'AZ-305',
    issuer: 'Microsoft Azure',
  },
  {
    name: 'OCI Cloud Infrastructure Architect',
    code: 'Professional',
    issuer: 'Oracle Cloud Infrastructure',
  },
  {
    name: 'OCI Multicloud Architect',
    code: 'Professional',
    issuer: 'Oracle Cloud Infrastructure',
  },
];
---

<section class="certs">
  <div class="certs__inner container">
    <div class="certs__list">
      <p class="certs__section-label">Certifications</p>
      <ul role="list">
        {certifications.map((cert) => (
          <li class="certs__item">
            <span class="certs__check" aria-hidden="true">
              <BadgeCheck size={18} aria-hidden="true" />
            </span>
            <div class="certs__item-text">
              <span class="certs__item-name">{cert.name}</span>
              <span class="certs__item-issuer">{cert.issuer}</span>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .certs {
    background-color: var(--color-surface);
    padding-block: var(--space-8);
  }

  .certs__inner {
    display: flex;
    align-items: flex-start;
  }

  .certs__section-label {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-on-surface-muted);
    margin-bottom: var(--space-4);
  }

  .certs__list {
    width: 100%;
  }

  .certs__list ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .certs__list ul {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-5) var(--space-8);
    }
  }

  .certs__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .certs__check {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .certs__item-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .certs__item-name {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    font-weight: var(--weight-semibold);
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }

  .certs__item-issuer {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    color: var(--color-on-surface-muted);
    letter-spacing: var(--tracking-wide);
  }
</style>