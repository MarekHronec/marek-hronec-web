---
/*
 * Two cards side by side: light left (career text) + dark right (expertise list).
 * No section background — the cards carry their own tonal surfaces so they
 * stay bounded at wide viewports rather than bleeding full-width.
 * align-items: stretch keeps both cards the same height regardless of content.
 */

import BookOpen from '../icons/BookOpen.astro';

const expertise = [
  'Cloud Architecture',
  'Process Orchestration',
  'Governance & Compliance',
  'FinOps & Cost Optimization',
  'Multi-Cloud Strategy',
];
---

<section class="narrative">
  <div class="narrative__inner container">

    <div class="narrative__text">

      <h2 class="narrative__heading">
        <BookOpen size={20} class="narrative__icon" aria-hidden="true" />
        The Narrative
      </h2>

      <div class="narrative__body">
        <p>
          Over nearly a decade in tech, I've moved through analysis, operations, support, and
          architecture into cloud-focused design. That journey taught me that strong
          architecture is not about adding more, but about making the right decisions with
          clarity.
        </p>
        <p>
          I believe that architecture is as much about communication as it is about code. My
          documentation-first approach ensures that stakeholders and engineers remain
          aligned throughout the lifecycle of a project.
        </p>
      </div>

    </div>

    <aside class="narrative__expertise">

      <p class="narrative__expertise-label">Core Expertise</p>

      <ul class="narrative__expertise-list" role="list">
        {expertise.map((item) => (
          <li class="narrative__expertise-item">
            <span class="narrative__expertise-dot" aria-hidden="true"></span>
            {item.toUpperCase()}
          </li>
        ))}
      </ul>

      <p class="narrative__expertise-footer">
        "Complexity is the enemy of reliability."
      </p>

    </aside>

  </div>
</section>

<style>
  .narrative {
    padding-block: 0 var(--space-3);
  }

  /* align-items: stretch so both cards grow to the same height */
  .narrative__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .narrative__inner {
      grid-template-columns: 1fr 300px;
      gap: var(--space-5);
    }
  }

  @media (min-width: 1024px) {
    .narrative__inner {
      grid-template-columns: 1fr 320px;
    }
  }

  .narrative__text {
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
  }

  .narrative__heading {
    font-family: var(--font-display);
    font-size: var(--text-title-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-on-surface);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .narrative__icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .narrative__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .narrative__body p {
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
  }

  /* Dark card — inverse-surface creates maximum contrast against the light left card */
  .narrative__expertise {
    background-color: var(--color-inverse-surface);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .narrative__expertise-label {
    font-family: var(--font-display);
    font-size: var(--text-title-lg);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-on-inverse-surface);
  }

  .narrative__expertise-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1; /* pushes the closing quote to the card bottom */
  }

  .narrative__expertise-item {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    color: rgba(244, 241, 240, 0.65);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .narrative__expertise-dot {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background-color: var(--color-primary);
    flex-shrink: 0;
  }

  /*
   * Hairline before the quote — one exception to the no-divider rule.
   * Inside a dark card, tonal shift can't create separation, so a very
   * low-opacity white line is used instead.
   */
  .narrative__expertise-footer {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-style: italic;
    color: rgba(244, 241, 240, 0.40);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: var(--space-4);
  }
</style>
