---
interface TechCategory {
  name: string;
  items: string[];
}

const categories: TechCategory[] = [
  {
    name: 'Infrastructure',
    items: ['Azure', 'OCI', 'Terraform', 'GitHub Actions', 'Entra ID'],
  },
  {
    name: 'Containers',
    items: ['Kubernetes', 'Azure App Service', 'Docker'],
  },
  {
    name: 'Orchestration',
    items: ['Camunda', 'Oracle BPM'],
  },
  {
    name: 'Observability',
    items: ['PowerBI', 'Tableau', 'Grafana', 'Cloud-native logs'],
  },
  {
    name: 'Languages',
    items: ['Go (in progress)'],
  },
];
---

<section class="techstack">
  <div class="techstack__inner container">
    <p class="techstack__label">Technical Stack</p>
    <div class="techstack__grid">
      {categories.map((cat) => (
        <div class="techstack__col">
          <h3 class="techstack__col-heading">{cat.name}</h3>
          <ul class="techstack__items" role="list">
            {cat.items.map((item) => (
              <li class="techstack__item">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .techstack {
    background-color: var(--color-surface);
    padding-block: var(--space-8);
  }

  .techstack__label {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-on-surface-muted);
    margin-bottom: var(--space-6);
  }

  .techstack__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6) var(--space-8);
  }

  @media (min-width: 640px) {
    .techstack__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .techstack__grid {
      grid-template-columns: repeat(5, 1fr);
      gap: var(--space-6) var(--space-10);
    }
  }

  .techstack__col-heading {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-on-surface);
    margin-bottom: var(--space-3);
  }

  .techstack__items {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .techstack__item {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    color: var(--color-on-surface-muted);
    line-height: var(--leading-snug);
  }
</style>