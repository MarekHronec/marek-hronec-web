---
/*
 * 3-column grid: [logo (1fr)] | [nav links (auto)] | [cta + hamburger (1fr)]
 * The equal 1fr outer columns push the auto-width center column into the
 * true visual middle of the bar regardless of logo or CTA width.
 * Glass: surface at 80% opacity + 24px backdrop-blur per DESIGN.md.
 */

import { base } from '../../utils/base';

const navLinks = [
  { label: 'About',          href: `${base}/` },
  { label: 'Case Studies',   href: `${base}/case-studies` },
  { label: 'Knowledge Base', href: `${base}/knowledge-base` },
];

const currentPath = Astro.url.pathname;

/** Returns true when the current page is this link or a child of it. */
const isActive = (href: string): boolean => {
  if (href === `${base}/`) {
    // Exact match only — prevents KB/CS sub-paths from lighting up the home link
    return currentPath === `${base}/` || currentPath === base;
  }
  return currentPath === href || currentPath.startsWith(href + '/');
};
---

<header class="header">
  <nav class="header__nav container" aria-label="Main navigation">

    <a class="header__logo" href={`${base}/`}>
      Marek Hronec
    </a>

    <!-- Center column — hidden on mobile, always visually centered on desktop because of the 1fr/auto/1fr grid -->
    <ul class="header__links" role="list">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            class:list={[
              'header__link',
              { 'header__link--active': isActive(href) },
            ]}
            href={href}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA (desktop) and hamburger (mobile) share this column; CSS shows/hides each at the right breakpoint -->
    <div class="header__actions">
      <a class="header__cta" href={`${base}/contact`}>Get in Touch</a>

      <button
        class="header__hamburger"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="header__hamburger-bar"></span>
        <span class="header__hamburger-bar"></span>
        <span class="header__hamburger-bar"></span>
      </button>
    </div>

  </nav>

  <div class="header__mobile-menu" id="mobile-menu" aria-hidden="true">
    <ul class="header__mobile-links" role="list">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            class:list={[
              'header__mobile-link',
              { 'header__mobile-link--active': isActive(href) },
            ]}
            href={href}
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a class="header__mobile-cta" href={`${base}/contact`}>Get in Touch</a>
      </li>
    </ul>
  </div>
</header>

<!-- No framework needed here — just toggling two aria attributes and a class -->
<script>
  const hamburger = document.querySelector('.header__hamburger') as HTMLButtonElement;
  const mobileMenu = document.querySelector('.header__mobile-menu') as HTMLElement;

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!isOpen));
    mobileMenu.setAttribute('aria-hidden', String(isOpen));
    mobileMenu.classList.toggle('header__mobile-menu--open');
    hamburger.classList.toggle('header__hamburger--open');
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom: 1px solid var(--glass-border);
  }

  /* Mobile: logo left, hamburger right — no centering needed */
  .header__nav {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    height: 4rem;
  }

  /* Desktop: 1fr / auto / 1fr keeps nav links perfectly centered */
  @media (min-width: 768px) {
    .header__nav {
      grid-template-columns: 1fr auto 1fr;
    }
  }

  .header__logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    letter-spacing: -0.0625rem;
    justify-self: start;
    white-space: nowrap;
  }

  .header__logo:hover {
    opacity: 1;
    color: var(--color-primary);
  }

  .header__links {
    display: none;
    align-items: center;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .header__links {
      display: flex;
    }
  }

  .header__link {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: var(--weight-medium);
    color: var(--color-on-surface-muted);
    transition: color var(--duration-fast) var(--ease-standard);
    white-space: nowrap;
    padding-bottom: 4px; /* space for the active underline */
  }

  .header__link:hover {
    color: var(--color-on-surface);
    opacity: 1;
  }

  .header__link--active {
    color: var(--color-on-surface);
    font-weight: var(--weight-bold);
    opacity: 1;
    border-bottom: 2px solid var(--color-primary);
  }

  .header__actions {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .header__cta {
    display: none;
    padding: var(--space-2) var(--space-5);
    background: var(--gradient-cta);
    color: var(--color-on-primary);
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    transition:
      transform var(--duration-fast) var(--ease-standard),
      opacity var(--duration-fast) var(--ease-standard);
  }

  @media (min-width: 768px) {
    .header__cta {
      display: inline-flex;
      align-items: center;
    }
  }

  .header__cta:hover {
    opacity: 1;
    transform: translateY(-2px);
  }

  /* Three bars animate into an ✕ when open */
  .header__hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-2);
  }

  @media (min-width: 768px) {
    .header__hamburger {
      display: none;
    }
  }

  .header__hamburger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-on-surface);
    border-radius: var(--radius-full);
    transition:
      transform var(--duration-normal) var(--ease-standard),
      opacity  var(--duration-normal) var(--ease-standard);
  }

  .header__hamburger--open .header__hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .header__hamburger--open .header__hamburger-bar:nth-child(2) {
    opacity: 0;
  }
  .header__hamburger--open .header__hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .header__mobile-menu {
    display: none;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-top: 1px solid var(--glass-border);
  }

  /* Only show when open on mobile; always hidden on desktop via the base display:none */
  @media (max-width: 767px) {
    .header__mobile-menu--open {
      display: block;
    }
  }

  @media (min-width: 768px) {
    .header__mobile-menu {
      display: none;
    }
  }

  .header__mobile-links {
    display: flex;
    flex-direction: column;
    padding: var(--space-4) var(--gutter) var(--space-6);
    gap: var(--space-1);
  }

  .header__mobile-link {
    display: block;
    padding: var(--space-3) 0;
    font-family: var(--font-body);
    font-size: var(--text-title-md);
    font-weight: var(--weight-medium);
    color: var(--color-on-surface-muted);
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .header__mobile-link:hover,
  .header__mobile-link--active {
    color: var(--color-on-surface);
    opacity: 1;
  }

  .header__mobile-cta {
    display: inline-flex;
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-6);
    background: var(--gradient-cta);
    color: var(--color-on-primary);
    font-size: var(--text-body-lg);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-sm);
  }

  .header__mobile-cta:hover {
    opacity: 0.9;
  }
</style>
