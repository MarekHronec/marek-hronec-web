---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategorySidebar from '../../components/knowledge-base/CategorySidebar.astro';
import ArticleCard from '../../components/knowledge-base/ArticleCard.astro';
import SortIcon from '../../components/icons/SortIcon.astro';
import KBSearch from '../../components/knowledge-base/KBSearch.astro';
import { getCollection } from 'astro:content';
import { kbReadTime } from '../../utils/readTime';

const articles = await getCollection('knowledgeBase');

/* Sort newest first (default) */
const sorted = articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

/* ── Platform / topic derivation ─────────────────────────────────
   Platform: articles whose category is a cloud platform (azure, oci, gcp)
   Topics:   derived from category (for topic-category articles)
             + from tags (Networking, Identity, Security, FinOps, Landing Zones)
──────────────────────────────────────────────────────────────── */
const PLATFORM_CATS = new Set(['azure', 'oci', 'gcp']);
const TOPIC_CATS = new Set(['networking', 'identity', 'security', 'finops', 'devops', 'bpm']);
const TAG_TO_TOPIC: Record<string, string> = {
  'Networking':    'networking',
  'Identity':      'identity',
  'Security':      'security',
  'FinOps':        'finops',
  'Landing Zones': 'landing-zones',
  'DevOps':        'devops',
  'BPM':           'bpm',
};

function getArticlePlatforms(article: typeof sorted[0]): string {
  return PLATFORM_CATS.has(article.data.category) ? article.data.category : '';
}

function getArticleTopics(article: typeof sorted[0]): string {
  const topics = new Set<string>();
  const cat = article.data.category;
  if (TOPIC_CATS.has(cat)) topics.add(cat);
  for (const tag of article.data.tags) {
    const mapped = TAG_TO_TOPIC[tag];
    if (mapped) topics.add(mapped);
  }
  return Array.from(topics).join(',');
}

const totalCount = sorted.length;
---

<BaseLayout
  title="Knowledge Base"
  description="Technical articles on cloud architecture, Azure, DevOps, and infrastructure patterns."
>
  <div class="kb-page">

    <CategorySidebar />

    <div class="kb-content">
      <div class="kb-content__inner">

        <!-- Page header -->
        <header class="kb-header">
          <p class="kb-header__label">Knowledge Base</p>
          <h1 class="kb-header__title">Technical Notes<span class="kb-header__period">.</span></h1>
          <p class="kb-header__subtitle">
            In-depth architecture patterns, implementation guides, and
            operational constraints for cloud-native systems.
          </p>
        </header>

        <!-- Full-text search (Pagefind — index generated at build time) -->
        <KBSearch />

        <!-- Toolbar: article count + active filter chips + sort -->
        <div class="kb-toolbar">
          <p class="kb-toolbar__count">
            <span id="kb-article-count">{totalCount}</span>
            <span id="kb-article-count-label">{totalCount === 1 ? 'article' : 'articles'}</span>
          </p>
          <div class="kb-toolbar__chips" id="kb-chips" hidden></div>
          <div class="kb-toolbar__sort">
            <SortIcon size={14} class="kb-toolbar__sort-icon" aria-hidden="true" />
            <div class="kb-sort-wrap">
              <label class="visually-hidden" for="kb-sort">Sort by</label>
              <select id="kb-sort" class="kb-sort">
                <option value="latest">Latest first</option>
                <option value="oldest">Oldest first</option>
                <option value="title">Title A–Z</option>
              </select>
              <svg class="kb-sort-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </div>

        <!-- Article list -->
        {sorted.length > 0 ? (
          <div class="kb-list" id="kb-grid">
            {sorted.map((article) => (
              <div
                class="kb-card-wrapper"
                data-platforms={getArticlePlatforms(article)}
                data-topics={getArticleTopics(article)}
                data-date={article.data.date.toISOString()}
                data-title={article.data.title}
              >
                <ArticleCard
                  slug={article.id}
                  title={article.data.title}
                  category={article.data.category}
                  excerpt={article.data.excerpt}
                  date={article.data.date}
                  readTime={kbReadTime(article.body ?? '', article.data.category, article.data.readTime)}
                  level={article.data.level}
                  tags={article.data.tags}
                />
              </div>
            ))}
          </div>
        ) : (
          <p class="kb-empty">No articles published yet.</p>
        )}

        <p class="kb-empty kb-empty--filtered" id="kb-filter-empty" hidden>
          No articles match the selected filters.
        </p>

        <nav class="kb-pagination" id="kb-pagination" aria-label="Article pagination" hidden></nav>

      </div>
    </div>

  </div>
</BaseLayout>

<style>
  /* ── Two-column layout ──────────────────────────────────────────── */
  .kb-page {
    display: flex;
    align-items: stretch;
    flex: 1;
    min-height: 0;
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
  }

  /* Hide filter panel on mobile */
  .kb-page :global(.kb-filter) {
    display: none;
  }

  @media (min-width: 768px) {
    .kb-page :global(.kb-filter) {
      display: block;
    }
  }

  /* Content panel */
  .kb-content {
    flex: 1;
    min-width: 0;
    padding: var(--space-6) var(--space-5) calc(var(--space-10) + 4rem);
  }

  @media (min-width: 768px) {
    .kb-content {
      padding: var(--space-8) var(--space-8) var(--space-10);
    }
  }

  @media (min-width: 1024px) {
    .kb-content {
      padding: var(--space-8) var(--space-10) var(--space-10);
    }
  }

  .kb-content__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* ── Page header ──────────────────────────────────────────────── */
  .kb-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding-top: var(--space-4);
  }

  .kb-header__label {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .kb-header__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, var(--text-display-lg));
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-on-surface);
  }

  .kb-header__period {
    color: var(--color-meta-label);
  }

  .kb-header__subtitle {
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
    max-width: 52ch;
  }

  /* ── Toolbar ──────────────────────────────────────────────────── */
  .kb-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    min-height: 2rem;
  }

  .kb-toolbar__count {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-kb-text-muted);
    white-space: nowrap;
    display: flex;
    gap: 0.3em;
  }

  .kb-toolbar__chips {
    display: flex;
    gap: var(--space-2);
    align-items: center;
    flex: 1;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .kb-toolbar__chips::-webkit-scrollbar {
    display: none;
  }

  .kb-toolbar__sort {
    margin-left: auto;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .kb-toolbar__sort-icon {
    color: var(--color-kb-text-muted);
    flex-shrink: 0;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .kb-toolbar__sort:hover .kb-toolbar__sort-icon {
    color: var(--color-primary);
  }

  /* Flex row: [select text] [chevron] — no overlap, no clipping */
  .kb-sort-wrap {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .kb-sort {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: normal; /* letter-spacing on <select> clips last char in Chrome — keep normal */
    text-transform: uppercase;
    color: var(--color-on-surface);
    background: transparent;
    border: none;
    outline: none;
    padding: var(--space-1) 0;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .kb-sort:hover,
  .kb-sort:focus-visible {
    color: var(--color-primary);
  }

  .kb-sort:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .kb-sort-chevron {
    pointer-events: none;
    flex-shrink: 0;
    color: var(--color-kb-text-muted);
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .kb-sort:hover ~ .kb-sort-chevron {
    color: var(--color-primary);
  }

  /* ── Article list (single column) ────────────────────────────── */
  .kb-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .kb-card-wrapper {
    display: flex;
  }

  .kb-empty {
    color: var(--color-on-surface-muted);
    font-size: var(--text-body-lg);
    padding: var(--space-8) 0;
  }

  /* ── Chip styles (dynamically rendered by JS) ─────────────────── */
  :global(.kb-chip) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: 3px var(--space-3);
    background: var(--color-level-advanced-bg);
    color: var(--color-level-advanced-text);
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-standard);
    white-space: nowrap;
  }

  :global(.kb-chip:hover) {
    background: var(--color-primary-container);
  }

  :global(.kb-chip--clear) {
    background: var(--color-surface-container-high);
    color: var(--color-on-surface-muted);
  }

  :global(.kb-chip--clear:hover) {
    background: var(--color-surface-container-highest, var(--color-outline-variant));
    color: var(--color-on-surface);
  }

  /* visually-hidden utility for accessible labels */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Pagination ─────────────────────────────────────────────────
     All children are JS-created so they don't carry the Astro scoped
     data attribute — :global() is required for every rule here.
  ─────────────────────────────────────────────────────────────── */
  :global(.kb-pagination) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding-top: var(--space-8);
  }

  /* Prev / Next */
  :global(.kb-page-nav) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    height: 2rem;
    padding: 0 var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-medium);
    letter-spacing: 0.02em;
    color: var(--color-on-surface-muted);
    background: transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  :global(.kb-page-nav:hover:not(:disabled)) {
    color: var(--color-on-surface);
  }

  :global(.kb-page-nav:disabled) {
    opacity: 0.25;
    cursor: not-allowed;
    pointer-events: none;
  }

  :global(.kb-page-nav:focus-visible) {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* Page number buttons container */
  :global(.kb-pagination__pages) {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  /* Individual page number */
  :global(.kb-page-num) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    height: 2rem;
    padding: 0 var(--space-1);
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-regular);
    color: var(--color-on-surface-muted);
    background: transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard);
  }

  :global(.kb-page-num:hover) {
    color: var(--color-on-surface);
    background: var(--color-surface-container-low);
  }

  :global(.kb-page-num[aria-current="page"]) {
    color: var(--color-primary);
    font-weight: var(--weight-semibold);
    background: var(--color-surface-container);
  }

  :global(.kb-page-num:focus-visible) {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Ellipsis */
  :global(.kb-page-ellipsis) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    height: 2rem;
    font-size: var(--text-label-md);
    color: var(--color-on-surface-muted);
    opacity: 0.5;
    pointer-events: none;
    user-select: none;
  }

  /* Mobile compact: "2 / 5" */
  :global(.kb-pagination__compact) {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    color: var(--color-on-surface-muted);
    letter-spacing: 0.04em;
  }

  @media (min-width: 480px) {
    :global(.kb-pagination__compact) { display: none; }
  }

  @media (max-width: 479px) {
    :global(.kb-pagination__pages) { display: none; }
  }
</style>

<script>
  (function () {
    'use strict';

    /* ── Label maps ─────────────────────────────────────────────── */
    const LABELS: Record<string, Record<string, string>> = {
      platform: { azure: 'Azure', oci: 'OCI', gcp: 'GCP' },
      topic: {
        networking: 'Networking', identity: 'Identity', security: 'Security',
        finops: 'FinOps', 'landing-zones': 'Landing Zones', devops: 'DevOps', bpm: 'BPM',
      },
    };

    /* ── Constants ──────────────────────────────────────────────── */
    const PAGE_SIZE = 15;

    /* ── State ──────────────────────────────────────────────────── */
    const activePlatforms = new Set<string>();
    const activeTopics = new Set<string>();
    let activeSort = 'latest';
    let currentPage = 1;

    /* ── DOM refs ───────────────────────────────────────────────── */
    const grid = document.getElementById('kb-grid');
    const countEl = document.getElementById('kb-article-count');
    const countLabelEl = document.getElementById('kb-article-count-label');
    const chipsEl = document.getElementById('kb-chips') as HTMLElement | null;
    const allArticlesBtn = document.getElementById('kb-all-articles');
    const allCountEl = document.getElementById('kb-all-count');
    const mobileAllBtn = document.getElementById('kb-mobile-all-articles');
    const mobileAllCountEl = document.getElementById('kb-mobile-all-count');
    const sortEl = document.getElementById('kb-sort') as HTMLSelectElement | null;
    const emptyEl = document.getElementById('kb-filter-empty');
    const mobileBadge = document.getElementById('kb-mobile-badge');
    const paginationEl = document.getElementById('kb-pagination') as HTMLElement | null;

    /* All article wrappers — order matches server-rendered (newest first) */
    const wrappers = Array.from(
      document.querySelectorAll<HTMLElement>('[data-platforms]')
    );

    /* ── Init from URL ──────────────────────────────────────────── */
    const params = new URLSearchParams(window.location.search);
    (params.get('platforms') ?? '').split(',').filter(Boolean).forEach(v => activePlatforms.add(v));
    (params.get('topics') ?? '').split(',').filter(Boolean).forEach(v => activeTopics.add(v));
    activeSort = params.get('sort') ?? 'latest';
    if (sortEl) sortEl.value = activeSort;
    currentPage = parseInt(params.get('page') ?? '1', 10) || 1;

    /* ── Helpers ────────────────────────────────────────────────── */
    function getPlatforms(w: HTMLElement): string[] {
      return (w.dataset.platforms ?? '').split(',').filter(Boolean);
    }
    function getTopics(w: HTMLElement): string[] {
      return (w.dataset.topics ?? '').split(',').filter(Boolean);
    }

    function matchesFilter(w: HTMLElement): boolean {
      const platOk = activePlatforms.size === 0 || getPlatforms(w).some(p => activePlatforms.has(p));
      const topicOk = activeTopics.size === 0 || getTopics(w).some(t => activeTopics.has(t));
      return platOk && topicOk;
    }

    /* Count for a single filter button, respecting the OTHER group's active filters */
    function countForBtn(group: string, value: string): number {
      return wrappers.filter(w => {
        if (group === 'platform') {
          const platMatch = getPlatforms(w).includes(value);
          const topicMatch = activeTopics.size === 0 || getTopics(w).some(t => activeTopics.has(t));
          return platMatch && topicMatch;
        } else {
          const topicMatch = getTopics(w).includes(value);
          const platMatch = activePlatforms.size === 0 || getPlatforms(w).some(p => activePlatforms.has(p));
          return topicMatch && platMatch;
        }
      }).length;
    }

    function sortFn(a: HTMLElement, b: HTMLElement): number {
      if (activeSort === 'oldest') return (a.dataset.date ?? '').localeCompare(b.dataset.date ?? '');
      if (activeSort === 'title')  return (a.dataset.title ?? '').localeCompare(b.dataset.title ?? '');
      return (b.dataset.date ?? '').localeCompare(a.dataset.date ?? ''); /* latest (default) */
    }

    /* ── Scroll helper ──────────────────────────────────────────── */
    function scrollToArticles(): void {
      const toolbar = document.querySelector<HTMLElement>('.kb-toolbar');
      if (toolbar) {
        toolbar.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    /* ── Page range ─────────────────────────────────────────────── */
    function getPageRange(current: number, total: number): (number | '...')[] {
      if (total <= 7) {
        return Array.from({ length: total }, (_, i) => i + 1);
      }

      const rangeSet = new Set<number>();
      rangeSet.add(1);
      rangeSet.add(total);
      for (let i = current - 1; i <= current + 1; i++) {
        if (i >= 1 && i <= total) rangeSet.add(i);
      }

      const sorted = Array.from(rangeSet).sort((a, b) => a - b);
      const result: (number | '...')[] = [];
      for (let i = 0; i < sorted.length; i++) {
        if (i > 0 && sorted[i] - sorted[i - 1] > 1) {
          result.push('...');
        }
        result.push(sorted[i]);
      }
      return result;
    }

    /* ── Render pagination ──────────────────────────────────────── */
    function renderPagination(totalPages: number, current: number): void {
      if (!paginationEl) return;

      if (totalPages <= 1) {
        paginationEl.hidden = true;
        paginationEl.innerHTML = '';
        return;
      }

      paginationEl.hidden = false;
      paginationEl.innerHTML = '';

      /* Prev button */
      const prevBtn = document.createElement('button');
      prevBtn.className = 'kb-page-nav';
      prevBtn.setAttribute('aria-label', 'Go to previous page');
      prevBtn.disabled = current === 1;
      prevBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M8 2L4 6l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> Prev`;
      prevBtn.addEventListener('click', () => {
        currentPage = current - 1;
        apply();
        scrollToArticles();
      });
      paginationEl.appendChild(prevBtn);

      /* Compact "X / Y" for small screens */
      const compactSpan = document.createElement('span');
      compactSpan.className = 'kb-pagination__compact';
      compactSpan.setAttribute('aria-hidden', 'true');
      compactSpan.textContent = `${current} / ${totalPages}`;
      paginationEl.appendChild(compactSpan);

      /* Pages */
      const pagesDiv = document.createElement('div');
      pagesDiv.className = 'kb-pagination__pages';

      getPageRange(current, totalPages).forEach(item => {
        if (item === '...') {
          const ellipsis = document.createElement('span');
          ellipsis.className = 'kb-page-ellipsis';
          ellipsis.setAttribute('aria-hidden', 'true');
          ellipsis.textContent = '…';
          pagesDiv.appendChild(ellipsis);
        } else {
          const pageBtn = document.createElement('button');
          pageBtn.className = 'kb-page-num';
          pageBtn.setAttribute('aria-label', `Go to page ${item}`);
          if (item === current) pageBtn.setAttribute('aria-current', 'page');
          pageBtn.textContent = String(item);
          pageBtn.addEventListener('click', () => {
            currentPage = item as number;
            apply();
            scrollToArticles();
          });
          pagesDiv.appendChild(pageBtn);
        }
      });

      paginationEl.appendChild(pagesDiv);

      /* Next button */
      const nextBtn = document.createElement('button');
      nextBtn.className = 'kb-page-nav';
      nextBtn.setAttribute('aria-label', 'Go to next page');
      nextBtn.disabled = current === totalPages;
      nextBtn.innerHTML = `Next <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
      nextBtn.addEventListener('click', () => {
        currentPage = current + 1;
        apply();
        scrollToArticles();
      });
      paginationEl.appendChild(nextBtn);
    }

    /* ── Apply filter + sort ────────────────────────────────────── */
    function apply() {
      const visible = wrappers.filter(matchesFilter);
      const hidden  = wrappers.filter(w => !matchesFilter(w));

      visible.sort(sortFn);

      /* Pagination calculations */
      const totalPages = Math.max(1, Math.ceil(visible.length / PAGE_SIZE));
      if (currentPage > totalPages) currentPage = totalPages;
      const startIdx = (currentPage - 1) * PAGE_SIZE;
      const pageSlice = new Set(visible.slice(startIdx, startIdx + PAGE_SIZE));

      /* Re-order DOM: visible (sorted) first, hidden last */
      if (grid) {
        [...visible, ...hidden].forEach(w => grid.appendChild(w));
      }

      visible.forEach(w => { w.style.display = pageSlice.has(w) ? '' : 'none'; });
      hidden.forEach(w  => (w.style.display = 'none'));

      /* Article count */
      const n = visible.length;
      if (countEl) countEl.textContent = String(n);
      if (countLabelEl) countLabelEl.textContent = n === 1 ? 'article' : 'articles';

      /* Filter button active states + counts */
      document.querySelectorAll<HTMLElement>('[data-filter-group]').forEach(btn => {
        const group = btn.dataset.filterGroup ?? '';
        const value = btn.dataset.filterValue ?? '';
        const isActive = group === 'platform' ? activePlatforms.has(value) : activeTopics.has(value);
        btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        const countSpan = btn.querySelector('.kb-filter__count');
        if (countSpan) {
          const c = countForBtn(group, value);
          countSpan.textContent = c > 0 ? `[${c}]` : '';
        }
      });

      /* Mobile active-filter badge */
      const totalActive = activePlatforms.size + activeTopics.size;
      if (mobileBadge) {
        mobileBadge.textContent = String(totalActive);
        mobileBadge.hidden = totalActive === 0;
      }

      /* All Articles button + Clear filters state */
      const hasFilters = activePlatforms.size > 0 || activeTopics.size > 0;
      allArticlesBtn?.setAttribute('aria-pressed', hasFilters ? 'false' : 'true');
      mobileAllBtn?.setAttribute('aria-pressed', hasFilters ? 'false' : 'true');
      const totalLabel = `[${wrappers.length}]`;
      if (allCountEl) allCountEl.textContent = totalLabel;
      if (mobileAllCountEl) mobileAllCountEl.textContent = totalLabel;

      /* Chips */
      updateChips();

      /* Pagination */
      renderPagination(totalPages, currentPage);

      /* URL state */
      updateURL();

      /* Empty state */
      if (emptyEl) {
        emptyEl.hidden = !(hasFilters && n === 0);
      }
    }

    /* ── Chips ──────────────────────────────────────────────────── */
    function updateChips() {
      if (!chipsEl) return;
      chipsEl.innerHTML = '';
      const chips = [
        ...[...activePlatforms].map(v => ({ group: 'platform', value: v })),
        ...[...activeTopics].map(v  => ({ group: 'topic',    value: v })),
      ];

      if (chips.length > 0) {
        const clearAll = document.createElement('button');
        clearAll.className = 'kb-chip kb-chip--clear';
        clearAll.setAttribute('aria-label', 'Clear all filters');
        clearAll.innerHTML = `Clear filters <span aria-hidden="true">×</span>`;
        clearAll.addEventListener('click', () => {
          activePlatforms.clear();
          activeTopics.clear();
          currentPage = 1;
          apply();
        });
        chipsEl.appendChild(clearAll);
      }

      chips.forEach(({ group, value }) => {
        const label = LABELS[group]?.[value] ?? value;
        const btn = document.createElement('button');
        btn.className = 'kb-chip';
        btn.setAttribute('aria-label', `Remove filter: ${label}`);
        btn.innerHTML = `${label} <span aria-hidden="true">×</span>`;
        btn.addEventListener('click', () => {
          if (group === 'platform') activePlatforms.delete(value);
          else activeTopics.delete(value);
          currentPage = 1;
          apply();
        });
        chipsEl.appendChild(btn);
      });
      chipsEl.hidden = chips.length === 0;
    }

    /* ── URL state ──────────────────────────────────────────────── */
    function updateURL() {
      const p = new URLSearchParams();
      if (activePlatforms.size > 0) p.set('platforms', [...activePlatforms].join(','));
      if (activeTopics.size > 0)    p.set('topics',    [...activeTopics].join(','));
      if (activeSort !== 'latest')  p.set('sort',      activeSort);
      if (currentPage > 1)          p.set('page',      String(currentPage));
      const qs = p.toString();
      history.replaceState(null, '', qs ? `?${qs}` : window.location.pathname);
    }

    /* ── Event bindings ─────────────────────────────────────────── */
    document.querySelectorAll<HTMLElement>('[data-filter-group]').forEach(btn => {
      btn.addEventListener('click', () => {
        const group = btn.dataset.filterGroup ?? '';
        const value = btn.dataset.filterValue ?? '';
        if (group === 'platform') {
          activePlatforms.has(value) ? activePlatforms.delete(value) : activePlatforms.add(value);
        } else {
          activeTopics.has(value) ? activeTopics.delete(value) : activeTopics.add(value);
        }
        currentPage = 1;
        apply();
      });
    });

    [allArticlesBtn, mobileAllBtn].forEach(btn => {
      btn?.addEventListener('click', () => {
        activePlatforms.clear();
        activeTopics.clear();
        currentPage = 1;
        apply();
      });
    });

    sortEl?.addEventListener('change', () => {
      activeSort = sortEl.value;
      currentPage = 1;
      apply();
    });

    /* ── Initial render ─────────────────────────────────────────── */
    apply();
  })();
</script>
