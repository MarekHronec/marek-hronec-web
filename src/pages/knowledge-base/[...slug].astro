---
/*
 * Knowledge Base article detail — /knowledge-base/[...slug]
 * Three columns: sidebar (220px) | article (flex:1) | TOC (200px, desktop only).
 */

import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategorySidebar from '../../components/knowledge-base/CategorySidebar.astro';
import ArticleOutline from '../../components/knowledge-base/ArticleOutline.astro';
import { kbReadTime } from '../../utils/readTime';
import { base } from '../../utils/base';

export async function getStaticPaths() {
  const entries = await getCollection('knowledgeBase');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, category, date, level, excerpt } = entry.data;
const { Content, headings } = await render(entry);
const readTime = kbReadTime(entry.body ?? '', category, entry.data.readTime);

/* Related articles — same category, excluding self */
const allArticles = await getCollection('knowledgeBase');
const related = allArticles
  .filter((a) => a.id !== entry.id && a.data.category === category)
  .slice(0, 2);

const levelLabel = { beginner: 'Beginner', intermediate: 'Intermediate', advanced: 'Advanced' }[level];
const dateStr = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

/* Breadcrumb: KNOWLEDGE BASE > CATEGORY > TITLE */
const categoryLabel = category.toUpperCase();
---

<BaseLayout title={title} description={excerpt}>
  <div class="kb-page">

    <CategorySidebar />

    <!-- Main content area -->
    <div class="kb-main">

      <!-- Breadcrumb -->
      <nav class="kb-breadcrumb" aria-label="Breadcrumb">
        <a class="kb-breadcrumb__link" href={`${base}/knowledge-base`}>Knowledge Base</a>
        <span class="kb-breadcrumb__sep" aria-hidden="true">›</span>
        <a class="kb-breadcrumb__link" href={`${base}/knowledge-base`}>{categoryLabel}</a>
        <span class="kb-breadcrumb__sep" aria-hidden="true">›</span>
        <span class="kb-breadcrumb__current">{title}</span>
      </nav>

      <!-- Article content.
           data-pagefind-body  — marks this element as the indexed content region.
           Pages without this attribute are not indexed, so only KB articles
           appear in search results (listing page, case studies, etc. are excluded).
           data-pagefind-meta  — passes the category value as searchable metadata
           so result rendering can display it without parsing the URL. -->
      <article class="kb-article" data-pagefind-body data-pagefind-meta={`category:${category}`}>

        <!-- Article header.
             data-pagefind-ignore — skips level badge and date/readtime text from
             the full-text index (they add noise), while still allowing the h1's
             data-pagefind-meta="title" to be extracted as the result title. -->
        <header class="kb-article__header" data-pagefind-ignore>

          <!-- Level badge -->
          <div class="kb-article__badge-row">
            <span class:list={['kb-article__badge', `kb-article__badge--${level}`]}>
              <!-- Leaf/level icon -->
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                <circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="5" cy="5" r="1.5" fill="currentColor"/>
              </svg>
              {levelLabel} Architecture
            </span>
          </div>

          <!-- Title: data-pagefind-meta="title" overrides the <title> tag value
               (which includes " — Marek Hronec") with the plain article title. -->
          <h1 class="kb-article__title" data-pagefind-meta="title">{title}</h1>

          <!-- Meta: date + read time -->
          <div class="kb-article__meta">
            <span class="kb-article__meta-item">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <rect x="1.5" y="2.5" width="11" height="10" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
                <path d="M1.5 5.5h11M4.5 1v3M9.5 1v3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
              Published {dateStr}
            </span>
            <span class="kb-article__meta-item">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.2"/>
                <path d="M7 4v3l2 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
              {readTime} min read
            </span>
          </div>

        </header>

        <!-- Prose body -->
        <div class="prose">
          <Content />
        </div>

        <!-- Related articles — same category, up to 2 -->

        {related.length > 0 && (
          /* data-pagefind-ignore="all" — completely excludes related article
             titles and excerpts from the index so they don't pollute results. */
          <section class="kb-related" data-pagefind-ignore="all">
            <h3 class="kb-related__heading">Related Notes</h3>
            <div class="kb-related__grid">
              {related.map((article) => (
                <a class="kb-related__card" href={`${base}/knowledge-base/${article.id}`}>
                  <span class="kb-related__card-category">{article.data.category.toUpperCase()}</span>
                  <h4 class="kb-related__card-title">{article.data.title}</h4>
                  <p class="kb-related__card-excerpt">{article.data.excerpt}</p>
                </a>
              ))}
            </div>
          </section>
        )}

      </article>

    </div>

    <!-- TOC — third column, sibling of sidebar so sticky fires at top of content -->
    <div class="kb-toc">
      <ArticleOutline headings={headings} />
    </div>

  </div>
</BaseLayout>

<style>
  /* ── Three-column layout — sidebar | article | TOC ──────────── */
  .kb-page {
    display: flex;
    align-items: stretch;
    flex: 1;
    min-height: 0;
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
  }

  /* Hide sidebar on mobile — bottom sheet handles category nav */
  .kb-page :global(.kb-filter) {
    display: none;
  }

  @media (min-width: 768px) {
    .kb-page :global(.kb-filter) {
      display: block;
    }
  }

  /* Right of sidebar: breadcrumb + article */
  .kb-main {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    padding: var(--space-6) var(--space-5) calc(var(--space-10) + 4rem);
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .kb-main {
      padding: var(--space-6) var(--space-8) var(--space-10);
    }
  }

  /* ── Breadcrumb ─────────────────────────────────────────────── */
  .kb-breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .kb-breadcrumb__link {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-regular);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-kb-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .kb-breadcrumb__link:hover {
    color: var(--color-primary);
    opacity: 1;
  }

  .kb-breadcrumb__sep {
    color: var(--color-kb-text-muted);
    font-size: var(--text-label-md);
  }

  .kb-breadcrumb__current {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-on-surface);
  }

  /* Article fills main column */
  .kb-article {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  /* TOC — third column in .kb-page, same level as sidebar.
     Starts at the top of the content area so sticky fires immediately. */
  .kb-toc {
    width: 200px;
    flex-shrink: 0;
    align-self: flex-start;
    position: sticky;
    top: 64px;
    padding-top: var(--space-6);
    display: none;
  }

  @media (min-width: 1024px) {
    .kb-toc {
      display: block;
    }
  }

  /* ── Article header ──────────────────────────────────────────── */
  .kb-article__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .kb-article__badge-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* Level badge — mint green tint at 2px radius */
  .kb-article__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: var(--weight-bold);
    letter-spacing: -0.03em;
    text-transform: uppercase;
    padding: 4px var(--space-2);
    border-radius: 2px;
  }

  .kb-article__badge--advanced {
    background-color: var(--color-level-advanced-bg);
    color: var(--color-level-advanced-text);
  }

  .kb-article__badge--intermediate {
    background-color: var(--color-level-intermediate-bg);
    color: var(--color-level-intermediate-text);
  }

  .kb-article__badge--beginner {
    background-color: var(--color-level-beginner-bg);
    color: var(--color-level-beginner-text);
  }

  .kb-article__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: var(--weight-bold);
    letter-spacing: -0.025em;
    line-height: var(--leading-tight);
    color: var(--color-on-surface);
  }

  .kb-article__meta {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    padding-top: var(--space-1);
  }

  .kb-article__meta-item {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    color: var(--color-kb-text);
  }

  .kb-article__meta-item svg {
    flex-shrink: 0;
    color: var(--color-kb-text-muted);
  }

  /* ── Prose body ──────────────────────────────────────────────── */
  .prose {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 68ch;
  }

  /* Intro paragraph (first <p>) — one step up from body-lg for a strong opening */
  .prose :global(p:first-child) {
    font-size: var(--text-title-md);
    line-height: 1.625;
    color: var(--color-on-surface-muted);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-headline-md);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-snug);
    margin-top: var(--space-4);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-title-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-on-surface);
    margin-top: var(--space-3);
  }

  .prose :global(p) {
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .prose :global(ul) { list-style: disc; }
  .prose :global(ol) { list-style: decimal; }

  .prose :global(li) {
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
  }

  .prose :global(strong) {
    font-weight: var(--weight-semibold);
    color: var(--color-on-surface);
  }

  /* Tables — wrapped in .prose-table-scroll by script below */
  .prose :global(.prose-table-scroll) {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--radius-md);
    background-color: var(--color-surface-container-lowest);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-body-md);
    border-radius: 0;
  }

  .prose :global(thead) {
    background-color: var(--color-surface-container);
  }

  .prose :global(th) {
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-on-surface);
    text-align: left;
  }

  .prose :global(td) {
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-body-md);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
    border-top: 1px solid var(--color-surface-container-high);
  }

  .prose :global(tbody tr:hover td) {
    background-color: var(--color-surface-container-low);
  }

  /* Code blocks — inverse-surface dark bg for high contrast */
  .prose :global(pre) {
    background-color: var(--color-inverse-surface);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    overflow-x: auto;
    font-size: var(--text-body-md);
    line-height: var(--leading-relaxed);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--color-code-accent); /* emerald green — syntax highlight on dark bg */
  }

  /* Inline code */
  .prose :global(:not(pre) > code) {
    background-color: var(--color-secondary-container);
    color: var(--color-on-surface);
    padding: 0.1em 0.35em;
    border-radius: var(--radius-sm);
    font-size: 0.875em;
  }

  /* Pro Tip callout */
  .prose :global(.callout-tip) {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-5);
    background-color: var(--color-surface-container-low);
    border-left: 4px solid var(--color-primary);
    border-radius: 4px;
  }

  .prose :global(.callout-tip__icon) {
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 2px;
  }

  .prose :global(.callout-tip__label) {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary-dim);
    margin-bottom: var(--space-1);
  }

  .prose :global(.callout-tip__content p:not(.callout-tip__label)) {
    font-size: var(--text-body-md);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
    margin-top: 0;
  }

  /* Warning callout */
  .prose :global(.callout-warning) {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-5);
    background-color: var(--color-callout-warning-bg);
    border-left: 4px solid var(--color-callout-warning-accent);
    border-radius: 4px;
  }

  .prose :global(.callout-warning__icon) {
    flex-shrink: 0;
    color: var(--color-callout-warning-accent);
    margin-top: 2px;
  }

  .prose :global(.callout-warning__label) {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-callout-warning-accent);
    margin-bottom: var(--space-1);
  }

  .prose :global(.callout-warning__content p:not(.callout-warning__label)) {
    font-size: var(--text-body-md);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
    margin-top: 0;
  }

  /* ── Related articles ────────────────────────────────────────── */
  .kb-related {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-top: var(--space-8);
  }

  .kb-related__heading {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-kb-text-muted);
  }

  .kb-related__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }

  /* Related card — surface-container-low, hover lifts to surface-container */
  .kb-related__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: background-color var(--duration-fast) var(--ease-standard);
  }

  .kb-related__card:hover {
    background-color: var(--color-surface-container);
    opacity: 1;
  }

  .kb-related__card-category {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .kb-related__card-title {
    font-family: var(--font-display);
    font-size: var(--text-title-md);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }

  .kb-related__card-excerpt {
    font-size: var(--text-label-md);
    line-height: var(--leading-relaxed);
    color: var(--color-kb-text);
  }
</style>

<script>
  document.querySelectorAll('.prose table').forEach(table => {
    const wrapper = document.createElement('div');
    wrapper.className = 'prose-table-scroll';
    table.parentNode?.insertBefore(wrapper, table);
    wrapper.appendChild(table);
  });
</script>