---
/*
 * Credentials — /credentials
 * Full certification registry linked from the About page certifications card.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import TagBadge from '../components/shared/TagBadge.astro';

interface Cert {
  name: string;
  issuer: string;
  year: number;
  status: 'active' | 'legacy';
  verifyUrl: string;
  domain: string;
}

interface CertGroup {
  label: string;
  certs: Cert[];
}

/* Replace verifyUrl '#' values with real credential verification links */
const groups: CertGroup[] = [
  {
    label: 'Microsoft Azure',
    certs: [
      { name: 'Azure Solutions Architect Expert (AZ-305)', issuer: 'Microsoft',        year: 2024, status: 'active', verifyUrl: 'https://learn.microsoft.com/api/credentials/share/en-us/MarekHronec-1478/DD55CCBCE898468B?sharingId=61DB7B68FA95C360', domain: 'Cloud' },
      { name: 'Azure Administrator Associate (AZ-104)',       issuer: 'Microsoft',        year: 2023, status: 'active', verifyUrl: 'https://learn.microsoft.com/api/credentials/share/en-us/MarekHronec-1478/834C077D3F96058C?sharingId=61DB7B68FA95C360', domain: 'Cloud' },
      { name: 'Azure Fundamentals (AZ-900)',     issuer: 'Microsoft',        year: 2023, status: 'active', verifyUrl: 'https://learn.microsoft.com/api/credentials/share/en-us/MarekHronec-1478/F19F39B679A4E312?sharingId=61DB7B68FA95C360', domain: 'Cloud' },
      { name: 'Azure AI Engineer Associate (AI-102)',        issuer: 'Microsoft',        year: 2023, status: 'active', verifyUrl: 'https://learn.microsoft.com/api/credentials/share/en-us/MarekHronec-1478/2CF27DC31CAB9A77?sharingId=61DB7B68FA95C360', domain: 'AI' },
      { name: 'Azure AI Fundamentals (AI-900)',     issuer: 'Microsoft',        year: 2023, status: 'active', verifyUrl: 'https://learn.microsoft.com/api/credentials/share/en-us/MarekHronec-1478/2CF27DC31CAB9A77?sharingId=61DB7B68FA95C360', domain: 'AI' },
    ],
  },
  {
    label: 'Oracle Cloud Infrastructure (OCI)',
    certs: [
      { name: 'Oracle Cloud Infrastructure 2025 Certified DevOps Professional (1Z0-1109-25)',               issuer: 'Oracle University', year: 2025, status: 'active', verifyUrl: 'https://catalog-education.oracle.com/pls/certview/sharebadge?id=44196AE7F07DE45152B9CEEC035B0464F7347F2932FCAFA8CD9130A2967A0D67', domain: 'DevOps' },
      { name: 'Oracle Cloud Infrastructure 2025 Certified Architect Associate (1Z0-1072-25)',               issuer: 'Oracle University', year: 2025, status: 'active', verifyUrl: 'https://catalog-education.oracle.com/pls/certview/sharebadge?id=AC039E74041F195F572BEA4F2A3022CF7E69178354F22816F1215D5F4F5ED3EA', domain: 'Cloud' },
      { name: 'Oracle Cloud Infrastructure 2025 Certified Multicloud Architect Professional (1Z0-1151-25)', issuer: 'Oracle University', year: 2024, status: 'active', verifyUrl: 'https://catalog-education.oracle.com/pls/certview/sharebadge?id=6EA5B76B8D43721305CD59019AC6D485C6FDA8D2D19FF114A0B38BC067D997FD', domain: 'Multicloud' },
    ],
  },
  {
    label: 'Amazon Web Services',
    certs: [
      { name: 'AWS Certified Cloud Practitioner (CLF-C02)', issuer: 'AWS', year: 2022, status: 'active', verifyUrl: '#', domain: 'Cloud' },
    ],
  },
  {
    label: 'General',
    certs: [
      { name: 'ArchiMate® 3 Part 1 & 2', issuer: 'OpenGroup', year: 2024, status: 'active', verifyUrl: 'https://certification.opengroup.org/directory-certified-people?trk=public_profile_see-credential', domain: 'General' },
    ],
  },
  {
    label: 'Legacy',
    certs: [
      { name: 'Cisco Certified Network Associate (CCNA)', issuer: 'Cisco', year: 2013, status: 'legacy', verifyUrl: '#', domain: 'Networking' },
    ],
  },
];
---

<BaseLayout
  title="Credentials"
  description="Full registry of professional certifications — Microsoft Azure, Oracle Cloud Infrastructure, and industry standards."
>

  <!-- ── Page header ─────────────────────────────────────────────── -->
  <section class="cred-hero">
    <div class="cred-hero__inner container">

      <div class="cred-hero__content">
        <p class="cred-hero__label">Professional Credentials</p>
        <h1 class="cred-hero__heading">
          Validated Architectural <span class="cred-hero__accent">Expertise</span><span class="cred-hero__period">.</span>
        </h1>
        <p class="cred-hero__subtitle">
          A curated collection of industry-leading certifications spanning
          cloud infrastructure, architecture, DevOps, and networking.
        </p>
      </div>

    </div>
  </section>

  <!-- ── Certification groups ────────────────────────────────────── -->
  <section class="cred-section">
    <div class="cred-section__inner container">

      {groups.map((group) => (
        <div class="cred-group">

          <!-- Group heading -->
          <div class="cred-group__header">
            <h2 class="cred-group__heading">{group.label.toUpperCase()}</h2>
          </div>

          <!-- Column labels — desktop only -->
          <div class="cred-table__labels" aria-hidden="true">
            <span class="cred-table__col--name">Credential</span>
            <span class="cred-table__col--domain">Domain</span>
            <span class="cred-table__col--issuer">Issuer</span>
            <span class="cred-table__col--year">Issued</span>
            <span class="cred-table__col--verify">Verification</span>
          </div>

          <!-- Cert rows -->
          <ul class="cred-table" role="list">
            {group.certs.map((cert) => (
              <li class="cred-row">
                <span class="cred-row__name">{cert.name}</span>
                <span class="cred-row__domain"><TagBadge label={cert.domain} /></span>
                <span class="cred-row__issuer">{cert.issuer}</span>
                <span class="cred-row__year">{cert.year}</span>
                <span class="cred-row__verify">
                  {cert.status === 'legacy' ? (
                    <span class="cred-row__legacy">Legacy</span>
                  ) : cert.verifyUrl !== '#' ? (
                    <a class="cred-row__verify-link" href={cert.verifyUrl} target="_blank" rel="noopener noreferrer">
                      Verify
                    </a>
                  ) : (
                    <span class="cred-row__pending">Pending</span>
                  )}
                </span>
              </li>
            ))}
          </ul>

        </div>
      ))}

    </div>
  </section>

</BaseLayout>

<style>
  /* ── Page hero ───────────────────────────────────────────────────── */
  .cred-hero {
    padding-block: var(--space-8) var(--space-6);
  }

  .cred-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
  }

  .cred-hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding-top: var(--space-4);
  }

  .cred-hero__label {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .cred-hero__heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, var(--text-display-lg));
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-on-surface);
  }

  .cred-hero__accent {
    color: var(--color-primary);
  }

  .cred-hero__period {
    color: var(--color-meta-label);
  }

  .cred-hero__subtitle {
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
    max-width: 52ch;
  }

  /* ── Certification section ────────────────────────────────────────── */
  .cred-section {
    padding-block: 0 var(--space-10);
  }

  .cred-section__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  /* ── Group ────────────────────────────────────────────────────────── */
  .cred-group {
    display: flex;
    flex-direction: column;
  }

  .cred-group__header {
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    padding: var(--space-4) var(--space-5);
  }

  .cred-group__heading {
    font-family: var(--font-display);
    font-size: var(--text-title-md);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-on-surface);
  }

  /* ── Column label row — desktop only ────────────────────────────── */
  .cred-table__labels {
    display: none;
  }

  @media (min-width: 768px) {
    .cred-table__labels {
      display: grid;
      grid-template-columns: 1fr 100px 140px 72px 100px;
      gap: var(--space-4);
      padding: var(--space-3) var(--space-5);
      background-color: var(--color-surface-container-low);
      font-family: var(--font-body);
      font-size: var(--text-label-md);
      font-weight: var(--weight-bold);
      letter-spacing: var(--tracking-wide);
      text-transform: uppercase;
      color: var(--color-kb-text-muted);
    }

    .cred-table__col--verify {
      text-align: right;
    }
  }

  /* ── Cert table (list of rows) ───────────────────────────────────── */
  .cred-table {
    display: flex;
    flex-direction: column;
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
  }

  /* ── Individual cert row ─────────────────────────────────────────── */
  .cred-row {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      'name   verify'
      'issuer domain';
    gap: var(--space-2) var(--space-3);
    align-items: center;
    padding: var(--space-4) var(--space-5);
  }

  @media (min-width: 768px) {
    .cred-row {
      grid-template-columns: 1fr 100px 140px 72px 100px;
      grid-template-areas: 'name domain issuer year verify';
      align-items: center;
      gap: var(--space-4);
    }
  }

  .cred-row__name {
    grid-area: name;
    font-family: var(--font-display);
    font-size: var(--text-body-md);
    font-weight: var(--weight-semibold);
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }

  .cred-row__domain {
    grid-area: domain;
  }

  .cred-row__issuer {
    grid-area: issuer;
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    color: var(--color-on-surface-muted);
    line-height: var(--leading-snug);
  }

  .cred-row__year {
    grid-area: year;
    display: none;
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    color: var(--color-on-surface);
  }

  @media (min-width: 768px) {
    .cred-row__year {
      display: block;
    }
  }

  .cred-row__verify {
    grid-area: verify;
    display: flex;
    justify-content: flex-end;
  }

  .cred-row__verify-link {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-primary);
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-standard);
  }

  .cred-row__verify-link:hover {
    opacity: 0.7;
  }

  .cred-row__legacy,
  .cred-row__pending {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-meta-label);
  }
</style>
