---
/*
 * Case Studies listing — /case-studies
 * Featured card (white + shadow) on top, two equal cards below.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CaseStudyCard from '../../components/case-studies/CaseStudyCard.astro';
import CaseStudyMetrics from '../../components/case-studies/CaseStudyMetrics.astro';

const allStudies = await getCollection('caseStudies');
const featured   = allStudies.find((s) => s.data.featured);
const others     = allStudies.filter((s) => !s.data.featured);
---

<BaseLayout
  title="Case Studies"
  description="Real-world cloud architecture engagements — outcomes, metrics, and technical decisions."
>

  <!-- ── Hero — same spacing tokens as About page for consistent rhythm ── -->
  <section class="cs-hero">
    <div class="cs-hero__inner container">

      <div class="cs-hero__content">
        <p class="cs-hero__label">Principal Cloud Architect</p>
        <h1 class="cs-hero__heading">Case Studies.</h1>
        <p class="cs-hero__subtitle">
          Elite-level digital infrastructure strategy. I transform architectural
          complexity into scalable, cost-efficient, and resilient systems for
          global enterprises.
        </p>
      </div>

    </div>
  </section>

  <!-- ── Featured card — left: narrative (38%), right: dark diagram + tradeoffs row ── -->
  {featured && (
    <section class="cs-featured">
      <div class="container">
        <!-- Outer tray — surface-container-low with 4px inset padding -->
        <div class="cs-featured__tray">
          <article class="cs-featured__card">

            <!-- Left panel -->
            <div class="cs-featured__left">

              <span class="cs-featured__chip">Featured Project</span>

              <h2 class="cs-featured__title">{featured.data.title}</h2>

              <div class="cs-featured__meta">
                <div class="cs-featured__meta-item">
                  <span class="cs-featured__meta-label">Client</span>
                  <span class="cs-featured__meta-value">{featured.data.client}</span>
                </div>
                <div class="cs-featured__meta-item">
                  <span class="cs-featured__meta-label">Timeline</span>
                  <span class="cs-featured__meta-value">{featured.data.duration}</span>
                </div>
              </div>

              <!-- Problem + Outcome narrative blocks -->
              <div class="cs-featured__narrative">

                <div class="cs-featured__narrative-block">
                  <h3 class="cs-featured__narrative-heading">
                    <!-- Circle-i: problem/info icon -->
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.25"/>
                      <path d="M7 6v3.5M7 4.25v.5" stroke="currentColor" stroke-width="1.5"
                            stroke-linecap="round"/>
                    </svg>
                    The Problem
                  </h3>
                  <p class="cs-featured__narrative-body">
                    Monitoring stack failed at 400+ microservices. Telemetry costs
                    outpaced revenue growth while latency spikes remained undetected
                    until customer impact.
                  </p>
                </div>

                <div class="cs-featured__narrative-block">
                  <h3 class="cs-featured__narrative-heading">
                    <!-- Circle-check: outcome/success icon -->
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.25"/>
                      <path d="M4.5 7l2 2 3-3.5" stroke="currentColor" stroke-width="1.5"
                            stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    The Outcome
                  </h3>
                  <CaseStudyMetrics metrics={featured.data.metrics} />
                </div>

              </div>

            </div>

            <!-- Right panel -->
            <div class="cs-featured__right">

              <!-- Diagram panel — replace src with a real architecture image when ready -->
              <div class="cs-featured__diagram" aria-label="Telemetry flow diagram">
                <!-- Swappable image — replace src to update the visual -->
                <img
                  class="cs-featured__diagram-img"
                  src="/images/case-study-featured.jpg"
                  alt="Hyper-scale telemetry architecture diagram"
                />
                <div class="cs-featured__diagram-overlay">
                  <div class="cs-featured__diagram-stages">
                    <span class="cs-featured__stage cs-featured__stage--active">Ingestion</span>
                    <span class="cs-featured__stage">Processing</span>
                    <span class="cs-featured__stage">Storage</span>
                    <span class="cs-featured__stage cs-featured__stage--active">Viz</span>
                  </div>
                  <p class="cs-featured__diagram-caption">Fig. 01: Telemetry Flow</p>
                </div>
              </div>

              <div class="cs-featured__bottom-row">

                <!-- Key Tradeoffs card -->
                <div class="cs-featured__tradeoffs">
                  <h4 class="cs-featured__tradeoffs-heading">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <!-- Central post -->
                      <line x1="7" y1="2" x2="7" y2="12" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                      <!-- Horizontal beam -->
                      <line x1="1" y1="4" x2="13" y2="4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                      <!-- Left pan strings -->
                      <line x1="2.5" y1="4" x2="2.5" y2="7" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
                      <!-- Left pan arc -->
                      <path d="M1 7 Q2.5 9.5 4 7" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" fill="none"/>
                      <!-- Right pan strings -->
                      <line x1="11.5" y1="4" x2="11.5" y2="8" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
                      <!-- Right pan arc (slightly lower = unbalanced) -->
                      <path d="M10 8 Q11.5 10.5 13 8" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" fill="none"/>
                      <!-- Base -->
                      <line x1="5" y1="12" x2="9" y2="12" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                    </svg>
                    Key Tradeoffs
                  </h4>
                  <ul class="cs-featured__tradeoffs-list">
                    <li>Accepted 5s lag for 40% cost reduction.</li>
                    <li>Sampled tracing for healthy traffic.</li>
                  </ul>
                </div>

                <div class="cs-featured__report-col">
                  <a class="cs-featured__report-link" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/case-studies/${featured.id}`}>
                    View Full Report
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5"
                            stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>

              </div>

            </div>

          </article>
        </div>
      </div>
    </section>
  )}

  <!-- ── Secondary cards — no outer tray, sit directly on the page surface ── -->
  <section class="cs-grid">
    <div class="cs-grid__inner container">
      {others.map((study, i) => (
        <CaseStudyCard
          slug={study.id}
          index={i + 2}
          category={study.data.industry}
          title={study.data.title}
          excerpt={study.data.excerpt}
          tags={study.data.tags.slice(0, 2)}
        />
      ))}
    </div>
  </section>

</BaseLayout>

<script>
  /* Hide diagram image on load error so the dark background shows through */
  document.querySelector<HTMLImageElement>('.cs-featured__diagram-img')
    ?.addEventListener('error', function () { this.style.display = 'none'; });
</script>

<style>
  /* ── Hero ────────────────────────────────────────────────────────
     Token-for-token copy of HeroSection.astro spacing so vertical
     rhythm is identical when navigating between pages.
  ─────────────────────────────────────────────────────────────────── */
  .cs-hero {
    padding-block: var(--space-8) var(--space-6);
  }

  .cs-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
  }

  .cs-hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);          /* 24px — label→heading, heading→subtitle */
    padding-top: var(--space-4);  /* 16px — top gap before label */
    max-width: 680px;             /* keep subtitle to a readable width */
  }

  /* ← identical to .hero__label */
  .cs-hero__label {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-primary);
  }

  /* ← identical to .hero__heading */
  .cs-hero__heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, var(--text-display-lg));
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-on-surface);
  }

  /* Wider max-width than .hero__body because the subtitle here runs longer */
  .cs-hero__subtitle {
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
    max-width: 52ch;
  }

  /* ── Featured section ─────────────────────────────────────────── */
  .cs-featured {
    padding-block: 0 var(--space-5);
  }

  /* Outer tray — surface-container-low with 4px inset padding */
  .cs-featured__tray {
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-md);
    padding: 4px;
  }

  /* White card with ambient shadow — sits inside the tray */
  .cs-featured__card {
    background-color: var(--color-surface-container-lowest);
    border-radius: calc(var(--radius-md) - 2px);
    box-shadow: 0px 1px 2px 0px rgba(0, 0, 0, 0.12);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .cs-featured__card {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-8);
    }
  }

  /* ── Left panel ─────────────────────────────────────────────── */
  .cs-featured__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    width: 100%;
  }

  @media (min-width: 768px) {
    .cs-featured__left {
      width: 38%;
      flex-shrink: 0;
    }
  }

  /* display: inline-flex → chip is only as wide as its text content */
  .cs-featured__chip {
    display: inline-flex;
    align-self: flex-start;           /* prevents stretch to full parent width */
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-regular);
    letter-spacing: 0.45px;
    text-transform: uppercase;
    color: rgba(29, 92, 66, 1);       /* darker variant of primary for contrast on mint bg */
    background-color: var(--color-cta-surface);   /* #b1f0ce */
    padding: 2px var(--space-2);
    border-radius: 2px;
  }

  .cs-featured__title {
    font-family: var(--font-display);
    font-size: var(--text-headline-md);
    font-weight: var(--weight-bold);
    letter-spacing: -0.025em;
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }

  /* Hairline borders top+bottom — 10% warm-gray opacity, barely visible */
  .cs-featured__meta {
    display: flex;
    gap: var(--space-10);             /* generous gap between CLIENT and TIMELINE */
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-warm-gray-10);
    border-bottom: 1px solid var(--color-warm-gray-10);
  }

  .cs-featured__meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cs-featured__meta-label {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-meta-label);
  }

  .cs-featured__meta-value {
    font-family: var(--font-display);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    color: var(--color-on-surface);
  }

  /* Problem + Outcome blocks */
  .cs-featured__narrative {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-2);
  }

  .cs-featured__narrative-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* "The Problem" / "The Outcome" headings with inline icon */
  .cs-featured__narrative-heading {
    font-family: var(--font-display);
    font-size: var(--text-body-md);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .cs-featured__narrative-heading svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .cs-featured__narrative-body {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
  }

  /* ── Right panel ────────────────────────────────────────────── */
  .cs-featured__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    flex: 1;
  }

  /* Dark diagram panel — position: relative so the overlay stage labels sit on top.
     When a real architecture diagram image is dropped in, it fills the dark bg. */
  .cs-featured__diagram {
    background-color: var(--color-inverse-surface);
    border-radius: 2px;
    position: relative;
    min-height: 300px;
    overflow: hidden;
    flex: 1;
  }

  /* Image covers the dark panel; JS hides it on load error so the dark bg shows */
  .cs-featured__diagram-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.6;                      /* dim so overlay labels stay readable */
  }

  /* Overlay — always on top of the image */
  .cs-featured__diagram-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;         /* stages sit at the bottom of the panel */
    gap: var(--space-3);
    padding: var(--space-6);
  }

  /* 4 pipeline stage boxes */
  .cs-featured__diagram-stages {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-2);
  }

  .cs-featured__stage {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    text-align: center;
    padding: var(--space-2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    background-color: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.2);
  }

  /* Active stages (Ingestion, Viz) — primary green tint */
  .cs-featured__stage--active {
    border-color: rgba(44, 105, 78, 0.4);
    background-color: rgba(44, 105, 78, 0.05);
    color: rgba(163, 226, 192, 1);
  }

  .cs-featured__diagram-caption {
    font-family: var(--font-mono);
    font-size: var(--text-label-md);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.2);
    text-align: right;
  }

  /* Bottom row — flex row so tradeoffs card and report link are side by side, not stacked */
  .cs-featured__bottom-row {
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    gap: var(--space-4);
  }

  /* Tradeoffs card — surface-container bg, grows to fill left half */
  .cs-featured__tradeoffs {
    flex: 1;
    background-color: var(--color-surface-container);
    border-radius: 2px;
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cs-featured__tradeoffs-heading {
    font-family: var(--font-display);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .cs-featured__tradeoffs-heading svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  /* Bullet list */
  .cs-featured__tradeoffs-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-left: var(--space-4);
    list-style: disc;
  }

  .cs-featured__tradeoffs-list li {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
  }

  /* Report link — no flex:1 so it sits naturally to the right of the tradeoffs card */
  .cs-featured__report-col {
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
    align-self: flex-end;
    flex-shrink: 0;
  }

  /* "View Full Report →" */
  .cs-featured__report-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-display);
    font-size: var(--text-label-md);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    transition: opacity var(--duration-fast) var(--ease-standard);
  }

  .cs-featured__report-link:hover {
    opacity: 0.75;
  }

  /* ── Secondary cards grid ───────────────────────────────────────
     Tonal contrast (page surface vs card bg) provides separation — no borders needed.
  ─────────────────────────────────────────────────────────────────── */
  .cs-grid {
    padding-block: 0 var(--space-6);
  }

  .cs-grid__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .cs-grid__inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>