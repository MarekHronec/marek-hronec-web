---
/*
 * Case Studies listing — /case-studies
 * Featured card (white + shadow) on top, two equal cards below.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CaseStudyCard from '../../components/case-studies/CaseStudyCard.astro';
import CaseStudyMetrics from '../../components/case-studies/CaseStudyMetrics.astro';
import { base } from '../../utils/base';

const allStudies = await getCollection('caseStudies');
const featured   = allStudies.find((s) => s.data.featured);
const others     = allStudies.filter((s) => !s.data.featured);
---

<BaseLayout
  title="Case Studies"
  description="Real-world cloud architecture engagements — outcomes, metrics, and technical decisions."
>

  <!-- ── Hero — same spacing tokens as About page for consistent rhythm ── -->
  <section class="cs-hero">
    <div class="cs-hero__inner container">

      <div class="cs-hero__content">
        <p class="cs-hero__label">Proven Cloud Solutions</p>
        <h1 class="cs-hero__heading">Case Studies<span class="cs-hero__period">.</span></h1>
        <p class="cs-hero__subtitle">
           Exploring real-world challenges and innovative solutions, these projects showcase my 
           ability to design and deliver cloud architectures that drive efficiency, scalability, 
           and resilience.
        </p>
      </div>

    </div>
  </section>

  <!-- ── Featured card — left: narrative (38%), right: dark diagram + tradeoffs row ── -->
  {featured && (
    <section class="cs-featured">
      <div class="container">
        <!-- Outer tray — surface-container-low with 4px inset padding -->
        <div class="cs-featured__tray">
          <article class="cs-featured__card">

            <!-- Content row: grid on desktop, column on mobile -->
            <div class="cs-featured__content-row">

              <!-- Diagram — col 2 row 1 on desktop, first on mobile -->
              <div class="cs-featured__diagram" aria-label="Government cloud governance model diagram">
                <img
                  class="cs-featured__diagram-img"
                  src="/images/case_study_01.webp"
                  alt="Government cloud governance architecture model"
                />
              </div>

              <!-- Left top — col 1 row 1: chip + title + meta -->
              <div class="cs-featured__left">

                <span class="cs-featured__chip">Featured Project</span>

                <h2 class="cs-featured__title">{featured.data.title}</h2>

                <div class="cs-featured__meta">
                  <div class="cs-featured__meta-item">
                    <span class="cs-featured__meta-label">Context</span>
                    <span class="cs-featured__meta-value">{featured.data.context}</span>
                  </div>
                  <div class="cs-featured__meta-item">
                    <span class="cs-featured__meta-label">Role</span>
                    <span class="cs-featured__meta-value">{featured.data.role}</span>
                  </div>
                </div>

              </div>

              <!-- Problem — col 1 row 2, aligns with Outcome on desktop -->
              <div class="cs-featured__problem">
                <h3 class="cs-featured__narrative-heading">
                  <svg width="20" height="20" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.25"/>
                    <path d="M7 6v3.5M7 4.25v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                  The Problem
                </h3>
                <p class="cs-featured__narrative-body">
                  Public-sector cloud adoption is not only an infrastructure problem. It requires a governed model for service selection, onboarding, identity, network boundaries, cost control and operational responsibility.
                </p>
              </div>

              <!-- Outcome + CTA — col 2 row 2, aligns with Problem on desktop -->
              <div class="cs-featured__outcome">
                <h3 class="cs-featured__narrative-heading">
                  <svg width="20" height="20" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.25"/>
                    <path d="M4.5 7l2 2 3-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  The Outcome
                </h3>
                <CaseStudyMetrics metrics={featured.data.metrics} />
                <a class="cs-featured__report-btn" href={`${base}/case-studies/${featured.id}`}>
                  View Full Report
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>

            </div>

          </article>
        </div>
      </div>
    </section>
  )}

  <!-- ── Secondary cards — no outer tray, sit directly on the page surface ── -->
  <section class="cs-grid">
    <div class="cs-grid__inner container">
      {others.map((study, i) => (
        <CaseStudyCard
          slug={study.id}
          index={i + 2}
          category={study.data.industry}
          title={study.data.title}
          excerpt={study.data.excerpt}
          tags={study.data.tags.slice(0, 2)}
        />
      ))}
    </div>
  </section>

</BaseLayout>

<script>
document.querySelector<HTMLImageElement>('.cs-featured__diagram-img')
    ?.addEventListener('error', function () { this.style.display = 'none'; });
</script>

<style>
  /* ── Hero ────────────────────────────────────────────────────────
     Token-for-token copy of HeroSection.astro spacing so vertical
     rhythm is identical when navigating between pages.
  ─────────────────────────────────────────────────────────────────── */
  .cs-hero {
    padding-block: var(--space-8) var(--space-6);
  }

  .cs-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
  }

  .cs-hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);          /* 24px — label→heading, heading→subtitle */
    padding-top: var(--space-4);  /* 16px — top gap before label */
    max-width: 680px;             /* keep subtitle to a readable width */
  }

  /* ← identical to .hero__label */
  .cs-hero__label {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-primary);
  }

  /* ← identical to .hero__heading */
  .cs-hero__heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, var(--text-display-lg));
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-on-surface);
  }

  .cs-hero__period {
    color: var(--color-meta-label);
  }

  /* Wider max-width than .hero__body because the subtitle here runs longer */
  .cs-hero__subtitle {
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
    max-width: 52ch;
  }

  /* ── Featured section ─────────────────────────────────────────── */
  .cs-featured {
    padding-block: 0 var(--space-5);
  }

  .cs-featured__tray {
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-md);
    padding: 4px;
  }

  .cs-featured__card {
    background-color: var(--color-surface-container-lowest);
    border-radius: calc(var(--radius-md) - 2px);
    box-shadow: var(--shadow-sm);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .cs-featured__card {
      padding: var(--space-8);
    }
  }

  /* Mobile: single column, source order = diagram → left → tradeoffs → btn */
  .cs-featured__content-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* Desktop: 2-col grid — problem and outcome share row 2 */
  @media (min-width: 768px) {
    .cs-featured__content-row {
      display: grid;
      grid-template-columns: 38% 1fr;
      grid-template-rows: auto auto;
      column-gap: var(--space-8);
      row-gap: var(--space-5);
    }

    .cs-featured__left {
      grid-column: 1;
      grid-row: 1;
    }

    .cs-featured__diagram {
      grid-column: 2;
      grid-row: 1;
      height: 100%;
      min-height: 183px;
    }

    .cs-featured__problem {
      grid-column: 1;
      grid-row: 2;
    }

    .cs-featured__outcome {
      grid-column: 2;
      grid-row: 2;
    }
  }

  /* ── Left panel ─────────────────────────────────────────────── */
  .cs-featured__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cs-featured__chip {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-regular);
    letter-spacing: 0.045em;
    text-transform: uppercase;
    color: var(--color-primary-dim);
    background-color: var(--color-cta-surface);
    padding: 2px var(--space-2);
    border-radius: 2px;
  }

  .cs-featured__title {
    font-family: var(--font-display);
    font-size: var(--text-headline-md);
    font-weight: var(--weight-bold);
    letter-spacing: -0.025em;
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }

  .cs-featured__meta {
    display: flex;
    gap: var(--space-8);
    padding-top: var(--space-2);
    padding-bottom: var(--space-2);
    border-top: 1px solid var(--color-warm-gray-10);
    border-bottom: 1px solid var(--color-warm-gray-10);
  }

  .cs-featured__meta-item {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .cs-featured__meta-label {
    font-family: var(--font-body);
    font-size: var(--text-label-sm);
    font-weight: var(--weight-regular);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-on-surface-muted);
  }

  .cs-featured__meta-value {
    font-family: var(--font-display);
    font-size: var(--text-body-md);
    font-weight: var(--weight-semibold);
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }

  .cs-featured__outcome {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    height: 100%;
  }

  .cs-featured__outcome .cs-featured__report-btn {
    margin-top: auto;
    align-self: flex-end;
  }

  .cs-featured__problem {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cs-featured__narrative-heading {
    font-family: var(--font-display);
    font-size: var(--text-body-md);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .cs-featured__narrative-heading svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .cs-featured__narrative-body {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
  }

  /* ── Diagram ────────────────────────────────────────────────── */
  .cs-featured__diagram {
    background-color: var(--color-inverse-surface);
    border-radius: 2px;
    position: relative;
    min-height: 180px;
    overflow: hidden;
  }

  @media (max-width: 767px) {
    .cs-featured__diagram {
      max-height: 220px;
    }
  }

  .cs-featured__diagram-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ── CTA button ─────────────────────────────────────────────── */
  .cs-featured__report-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: 0;
    background: transparent;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-sm);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    min-height: 44px;
    transition: background-color var(--duration-fast) var(--ease-standard),
                transform var(--duration-fast) var(--ease-standard);
  }

  .cs-featured__report-btn:hover {
    background-color: var(--color-cta-surface);
    transform: translateY(-2px);
  }

  @media (max-width: 767px) {
    .cs-featured__outcome .cs-featured__report-btn {
      align-self: stretch;
      margin-top: var(--space-2);
    }
  }

  @media (max-width: 539px) {
    .cs-featured__card {
      padding: var(--space-4);
    }
  }

  /* ── Secondary cards grid ───────────────────────────────────────
     Tonal contrast (page surface vs card bg) provides separation — no borders needed.
  ─────────────────────────────────────────────────────────────────── */
  .cs-grid {
    padding-block: 0 var(--space-6);
  }

  .cs-grid__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .cs-grid__inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>