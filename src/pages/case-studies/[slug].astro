---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagBadge from '../../components/shared/TagBadge.astro';
import Building  from '../../components/icons/Building.astro';
import Briefcase from '../../components/icons/Briefcase.astro';
import Factory   from '../../components/icons/Factory.astro';
import Layers    from '../../components/icons/Layers.astro';
import ListText  from '../../components/icons/ListText.astro';
import Shield    from '../../components/icons/Shield.astro';
import Activity  from '../../components/icons/Activity.astro';
import Tag       from '../../components/icons/Tag.astro';

export async function getStaticPaths() {
  const entries = await getCollection('caseStudies');
  const sorted = [...entries].sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return a.data.title.localeCompare(b.data.title);
  });
  return sorted.map((entry, index) => ({
    params: { slug: entry.id },
    props: { entry, caseStudyNumber: String(index + 1).padStart(2, '0') },
  }));
}

const { entry, caseStudyNumber } = Astro.props;
const {
  title, context, industry, role, tags, metrics, excerpt,
  heroImage, titleHighlight,
  platform, focus, principles, outcomes,
} = entry.data;

const hasHighlight = !!titleHighlight && title.includes(titleHighlight);
const titleBefore  = hasHighlight ? title.slice(0, title.indexOf(titleHighlight!)) : title;
const titleAfter   = hasHighlight ? title.slice(title.indexOf(titleHighlight!) + titleHighlight!.length) : '';
const { Content } = await render(entry);
---

<BaseLayout title={title} description={excerpt}>

  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="cs-hero">
    <div class="container">

      <!-- Full-width: eyebrow + title -->
      <div class="cs-hero__header">
        <p class="cs-hero__eyebrow">Case Study {caseStudyNumber}</p>
        <h1 class="cs-hero__title">
          {hasHighlight
            ? <>{titleBefore}<span class="cs-hero__title-accent">{titleHighlight}</span>{titleAfter}</>
            : titleBefore
          }<span class="cs-hero__title-period">.</span>
        </h1>
      </div>

      <!-- Lower row: excerpt + meta cards + chips (left) | illustration (right) -->
      <div class="cs-hero__lower">

        <div class="cs-hero__left">
          {excerpt && <p class="cs-hero__excerpt">{excerpt}</p>}

          <!-- 2×2 meta grid -->
          <div class="cs-meta-grid">

            <div class="cs-meta-card">
              <Building class="cs-meta-card__icon" size={24} aria-hidden="true" />
              <span class="cs-meta-card__label">Context</span>
              <span class="cs-meta-card__value">{context}</span>
            </div>

            <div class="cs-meta-card">
              <Briefcase class="cs-meta-card__icon" size={24} aria-hidden="true" />
              <span class="cs-meta-card__label">Role</span>
              <span class="cs-meta-card__value">{role}</span>
            </div>

            <div class="cs-meta-card">
              <Factory class="cs-meta-card__icon" size={24} aria-hidden="true" />
              <span class="cs-meta-card__label">Industry</span>
              <span class="cs-meta-card__value">{industry}</span>
            </div>

            <div class="cs-meta-card">
              <Layers class="cs-meta-card__icon" size={24} aria-hidden="true" />
              <span class="cs-meta-card__label">Platform</span>
              <span class="cs-meta-card__value">{platform ?? '—'}</span>
            </div>

          </div>

          <!-- Metric chips from frontmatter -->
          <div class="cs-chips">
            {metrics.map((m) => (
              <div class="cs-chip">
                <span class="cs-chip__value">{m.value}</span>
                <span class="cs-chip__label">{m.label}</span>
              </div>
            ))}
          </div>

        </div>

        <!-- Illustration -->
        {heroImage && (
          <div class="cs-hero__right">
            <div class="cs-hero__image-frame">
              <img
                class="cs-hero__img"
                src={heroImage}
                alt=""
                loading="eager"
              />
            </div>
          </div>
        )}

      </div>

    </div>
  </section>

  <!-- ── Body: prose + sidebar ─────────────────────────────────────── -->
  <div class="cs-body">
    <div class="container">
      <div class="cs-body__grid">

        <!-- Main prose content -->
        <article class="cs-body__main">
          <div class="prose">
            <Content />
          </div>
        </article>

        <!-- Right sidebar -->
        <aside class="cs-body__sidebar">

          <!-- At a Glance -->
          <div class="cs-sidebar-card">
            <h2 class="cs-sidebar-card__heading">
              <ListText size={20} aria-hidden="true" />
              At a Glance
            </h2>
            <dl class="cs-glance">
              {focus && (
                <div class="cs-glance__item">
                  <dd>{focus}</dd>
                </div>
              )}
            </dl>
          </div>

          <!-- Core Principles -->
          {principles && principles.length > 0 && (
            <div class="cs-sidebar-card">
              <h2 class="cs-sidebar-card__heading">
                <Shield size={20} aria-hidden="true" />
                Core Principles
              </h2>
              <ul class="cs-principles" role="list">
                {principles.map((p) => (
                  <li class="cs-principles__item">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    {p}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Key Outcomes -->
          {outcomes && outcomes.length > 0 && (
            <div class="cs-sidebar-card">
              <h2 class="cs-sidebar-card__heading">
                <Activity size={20} aria-hidden="true" />
                Key Outcomes
              </h2>
              <ul class="cs-outcomes" role="list">
                {outcomes.map((o) => (
                  <li class="cs-outcomes__item">
                    <span class="cs-outcomes__title">{o.title}</span>
                    <span class="cs-outcomes__desc">{o.description}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Tags -->
          <div class="cs-sidebar-card">
            <h2 class="cs-sidebar-card__heading">
              <Tag size={20} aria-hidden="true" />
              Tags
            </h2>
            <div class="cs-sidebar-tags">
              {tags.map((tag) => <TagBadge label={tag} />)}
            </div>
          </div>

        </aside>
      </div>
    </div>
  </div>

  <!-- ── Disclaimer ────────────────────────────────────────────────── -->
  <div class="cs-disclaimer">
    <div class="cs-disclaimer__inner container">
      <p class="cs-disclaimer__text">
        Some case studies are anonymized to respect confidentiality, security and contractual
        obligations. They focus on my role, architectural reasoning and lessons learned rather
        than disclosing client-sensitive implementation details.
      </p>
    </div>
  </div>

</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────────────────── */
  .cs-hero {
    padding-block: var(--space-8) var(--space-6);
  }

  /* Full-width title block — identical rhythm to About / Credentials heroes */
  .cs-hero__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding-top: var(--space-4);
    padding-bottom: var(--space-5);
  }

  /* Lower row: meta + chips left, image right */
  .cs-hero__lower {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .cs-hero__lower {
      grid-template-columns: 1fr 1fr;
      align-items: stretch;
      gap: var(--space-8);
    }
  }

  .cs-hero__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cs-hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .cs-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, var(--text-display-lg));
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-on-surface);
  }

  .cs-hero__title-period {
    color: var(--color-meta-label);
  }

  .cs-hero__title-accent {
    color: var(--color-primary);
  }

  .cs-hero__excerpt {
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
    max-width: 52ch;
  }

  /* ── Meta grid ─────────────────────────────────────────────────── */
  .cs-meta-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
  }

  @media (min-width: 640px) {
    .cs-meta-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .cs-meta-card {
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-sm);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cs-meta-card__icon {
    color: var(--color-on-surface-muted);
    margin-bottom: var(--space-1);
    flex-shrink: 0;
  }

  .cs-meta-card__label {
    font-family: var(--font-body);
    font-size: var(--text-label-sm);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-on-surface);
  }

  .cs-meta-card__value {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    font-weight: var(--weight-regular);
    color: var(--color-on-surface-muted);
    line-height: var(--leading-snug);
  }

  /* ── Metric chips ──────────────────────────────────────────────── */
  .cs-chips {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .cs-chip {
    flex: 1;
    min-width: 110px;
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 3px;
    border-left: 2px solid var(--color-primary);
  }

  .cs-chip__value {
    font-family: var(--font-display);
    font-size: var(--text-title-md);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    line-height: 1;
  }

  .cs-chip__label {
    font-family: var(--font-body);
    font-size: var(--text-label-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-on-surface-muted);
  }

  /* ── Hero image ────────────────────────────────────────────────── */
  .cs-hero__right {
    display: flex;
  }

  .cs-hero__image-frame {
    width: 100%;
    height: 100%;
    min-height: 280px;
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .cs-hero__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }

  /* ── Body: main + sidebar ──────────────────────────────────────── */
  .cs-body {
    padding-block: var(--space-4) var(--space-10);
  }

  .cs-body__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  .cs-body__main {
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .cs-body__grid {
      grid-template-columns: 1fr 260px;
      gap: var(--space-8);
    }

    .cs-body__sidebar {
      position: sticky;
      top: calc(4rem + var(--space-5));
    }
  }

  /* ── Prose ─────────────────────────────────────────────────────── */
  .prose {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-title-lg);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    letter-spacing: var(--tracking-tight);
    margin-top: var(--space-5);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .prose :global(h2:first-child) {
    margin-top: 0;
  }

  .prose :global(h2 svg) {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .prose :global(h2.prose-role) {
    color: var(--color-on-surface);
    border-bottom: 2px solid var(--color-on-surface);
    padding-bottom: var(--space-2);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-title-md);
    font-weight: var(--weight-semibold);
    color: var(--color-on-surface);
    margin-top: var(--space-5);
  }

  .prose :global(p) {
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .prose :global(ul) { list-style: disc; }
  .prose :global(ol) { list-style: decimal; }

  .prose :global(li) {
    font-size: var(--text-body-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
  }

  .prose :global(strong) {
    font-weight: var(--weight-semibold);
    color: var(--color-on-surface);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-quote-accent);
    background-color: var(--color-surface-container-low);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: var(--space-5) var(--space-6);
    margin: 0;
  }

  .prose :global(blockquote p) {
    color: var(--color-on-surface);
    font-size: var(--text-body-md);
  }

  .prose :global(pre) {
    overflow-x: auto;
    border-radius: var(--radius-md);
    padding: var(--space-5);
    font-family: var(--font-mono);
    font-size: var(--text-body-md);
    line-height: var(--leading-relaxed);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  .prose :global(pre code) {
    font-size: inherit;
  }

  /* ── Sidebar cards ─────────────────────────────────────────────── */
  .cs-body__sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cs-sidebar-card {
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-sm);
    padding: var(--space-4) var(--space-5);
  }

  .cs-sidebar-card__heading {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-on-surface);
    margin-bottom: var(--space-4);
  }

  .cs-sidebar-card__heading svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  /* At a Glance dl */
  .cs-glance {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cs-glance__item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cs-glance__item dt {
    font-family: var(--font-body);
    font-size: var(--text-label-sm);
    font-weight: var(--weight-regular);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-meta-label);
  }

  .cs-glance__item dd {
    font-family: var(--font-display);
    font-size: var(--text-body-md);
    font-weight: var(--weight-semibold);
    color: var(--color-on-surface);
    line-height: var(--leading-snug);
  }

  /* Core Principles list */
  .cs-principles {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cs-principles__item {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    line-height: var(--leading-snug);
    color: var(--color-on-surface-muted);
  }

  .cs-principles__item svg {
    color: var(--color-on-surface);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Key Outcomes list */
  .cs-outcomes {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cs-outcomes__item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cs-outcomes__title {
    font-family: var(--font-display);
    font-size: var(--text-body-md);
    font-weight: var(--weight-semibold);
    color: var(--color-on-surface);
  }

  .cs-outcomes__desc {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
  }

  /* Sidebar tags */
  .cs-sidebar-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* ── Disclaimer ─────────────────────────────────────────────────── */
  .cs-disclaimer {
    padding-block: 0 var(--space-8);
  }

  .cs-disclaimer__inner {
    max-width: var(--container-content);
  }

  .cs-disclaimer__text {
    font-family: var(--font-body);
    font-size: var(--text-label-md);
    line-height: var(--leading-relaxed);
    color: var(--color-on-surface-muted);
    opacity: 0.7;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-warm-gray-10);
  }
</style>
